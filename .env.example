# Job Hunter Configuration Template
# Copy this file to .env and fill in your actual values
# WARNING: Do NOT commit .env file to version control

# AWS Bedrock Configuration (if using AI features)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-west-2

# Google Cloud Configuration (for Google Cloud Talent Solution)
# Get this from your Google Cloud Console
GOOGLE_CLOUD_CREDENTIALS={"type": "service_account", ...}
GOOGLE_CLOUD_TENANT_NAME=projects/YOUR_PROJECT_ID/tenants/YOUR_TENANT_ID

# SerpAPI Configuration (for Google Jobs searching)
# Get free API key at https://serpapi.com/users/sign_up
SERPAPI_KEY=your_serpapi_key

# Adzuna Configuration
# Get credentials at https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# USAJobs Configuration  
# Get API key at https://developer.usajobs.gov/
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_EMAIL=your-email@example.com

# Drupal Configuration
DRUPAL_ENV=development
DEBUG=false

# File Storage
PRIVATE_FILE_PATH=private/

# Optional: Database Logging
DB_LOG_LEVEL=notice
