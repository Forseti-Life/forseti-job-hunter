{
  "name": "forseti-life/drupal-job-hunter",
  "description": "AI-powered job application automation with comprehensive job tracking, workflow management, and external service integration for Drupal.",
  "type": "drupal-module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Forseti-Life/drupal-job-hunter",
  "support": {
    "issues": "https://github.com/Forseti-Life/drupal-job-hunter/issues",
    "source": "https://github.com/Forseti-Life/drupal-job-hunter"
  },
  "authors": [
    {
      "name": "Job Hunter Development Team",
      "homepage": "https://github.com/Forseti-Life/drupal-job-hunter/graphs/contributors"
    }
  ],
  "keywords": [
    "drupal",
    "module",
    "job-search",
    "job-automation",
    "ai",
    "resume",
    "application-tracking"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://packages.drupal.org/8"
    }
  ],
  "require": {
    "drupal/core": "^10 || ^11",
    "guzzlehttp/guzzle": "^6.0 || ^7.0",
    "symfony/dependency-injection": "^5.0 || ^6.0",
    "symfony/console": "^5.0 || ^6.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0 || ^10.0",
    "squizlabs/php_codesniffer": "^3.0"
  },
  "suggest": {
    "drupal/ai_conversation": "Required for AI-powered resume tailoring and job analysis features"
  },
  "autoload": {
    "psr-4": {
      "Drupal\\job_hunter\\": "src/"
    }
  }
}
