<?php

/**
 * @file
 * Contains users_metrics.module.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\views\Plugin\views\query\QueryPluginBase;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_help().
 */
function users_metrics_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.users_metrics':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('The Users Metrics module provides statistical information about user registrations and logins.') . '</p>';
      return $output;

  }

  return NULL;
}

/**
 * Implements hook_theme().
 */
function users_metrics_theme() {
  return [
    'users_metrics_d3_chart' => [
      'variables' => [
        'chart_id' => NULL,
        'chart_type' => 'spline',
      ],
      'template' => 'users-metrics-d3-chart',
    ],
    'users_metrics_summary_cards' => [
      'variables' => [
        'total' => 0,
        'daily_avg' => 0,
        'peak_date' => NULL,
        'peak_value' => 0,
        'period_days' => 0,
        'metric_label' => 'items',
      ],
      'template' => 'users-metrics-summary-cards',
    ],
  ];
}

/**
 * Implements hook_form_views_exposed_form_alter().
 */
function users_metrics_form_views_exposed_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $view_ids = ['users_metrics_registrations', 'users_metrics_logins'];
  $view = $form_state->get('view');

  if ($form_id !== 'views_exposed_form' || !in_array($view->id(), $view_ids)) {
    return;
  }

  // Determine date field names based on view.
  $date_from_field = $view->id() === 'users_metrics_logins' ? 'timestamp_from' : 'created_from';
  $date_to_field = $view->id() === 'users_metrics_logins' ? 'timestamp_to' : 'created_to';

  // Alter date inputs to show an html5 date picker.
  if (isset($form[$date_from_field])) {
    $form[$date_from_field]['#type'] = 'date';
    $form[$date_from_field]['#weight'] = -5;
    $form[$date_from_field]['#wrapper_attributes']['class'][] = 'users-metrics-date-from';
  }

  if (isset($form[$date_to_field])) {
    $form[$date_to_field]['#type'] = 'date';
    $form[$date_to_field]['#weight'] = -4;
    $form[$date_to_field]['#wrapper_attributes']['class'][] = 'users-metrics-date-to';
  }

  // Add time range selector before date fields.
  $form['time_range'] = [
    '#type' => 'select',
    '#title' => t('Time range'),
    '#options' => [
      '' => t('- Custom -'),
      '24h' => t('Last 24 hours'),
      '7d' => t('Last week'),
      '30d' => t('Last month'),
      '90d' => t('Last 3 months'),
      '180d' => t('Last 6 months'),
      '365d' => t('Last year'),
    ],
    '#default_value' => '90d',
    '#weight' => -10,
    '#attributes' => [
      'class' => ['users-metrics-time-range'],
    ],
  ];

  $user_input = $form_state->getUserInput();

  // Check if time_range is set and calculate dates accordingly.
  if (!empty($user_input['time_range'])) {
    $dates = _users_metrics_get_dates_from_range($user_input['time_range']);
    if ($dates && isset($form[$date_from_field]) && isset($form[$date_to_field])) {
      $form[$date_from_field]['#value'] = $dates['from'];
      $form[$date_to_field]['#value'] = $dates['to'];
    }
  }
  elseif (isset($form[$date_from_field]) && empty($user_input[$date_from_field])) {
    // Default to 90 days if no input.
    $ninety_days_ago = date('Y-m-d', strtotime('-90 days'));
    $form[$date_from_field]['#value'] = $ninety_days_ago;
  }

  // Attach library for JavaScript interaction.
  $form['#attached']['library'][] = 'users_metrics/time_range';
}

/**
 * Get date range from time range option.
 *
 * @param string $range
 *   The time range option (24h, 7d, 30d, 90d, 180d, 365d).
 *
 * @return array|null
 *   Array with 'from' and 'to' dates, or NULL if invalid range.
 */
function _users_metrics_get_dates_from_range($range) {
  $today = date('Y-m-d');

  switch ($range) {
    case '24h':
      return [
        'from' => date('Y-m-d', strtotime('-1 day')),
        'to' => $today,
      ];

    case '7d':
      return [
        'from' => date('Y-m-d', strtotime('-7 days')),
        'to' => $today,
      ];

    case '30d':
      return [
        'from' => date('Y-m-d', strtotime('-30 days')),
        'to' => $today,
      ];

    case '90d':
      return [
        'from' => date('Y-m-d', strtotime('-90 days')),
        'to' => $today,
      ];

    case '180d':
      return [
        'from' => date('Y-m-d', strtotime('-180 days')),
        'to' => $today,
      ];

    case '365d':
      return [
        'from' => date('Y-m-d', strtotime('-365 days')),
        'to' => $today,
      ];

    default:
      return NULL;
  }
}

/**
 * Implements hook_views_pre_build().
 */
function users_metrics_views_pre_build(ViewExecutable $view) {
  $display_id = $view->current_display;
  // Handle dynamic field grouping for the by-field displays.
  $by_field_displays = ['page_by_field', 'table_by_field'];
  if ($view->id() === 'users_metrics_registrations' && in_array($display_id, $by_field_displays)) {
    // Get the group_field value directly from the request since exposed
    // input may not be available yet in pre_build.
    $group_field = \Drupal::request()->query->get('group_field', '');

    if (!empty($group_field)) {
      // Validate that the field is groupable.
      /** @var \Drupal\users_metrics\Service\FieldLabelResolver $field_label_resolver */
      $field_label_resolver = \Drupal::service('users_metrics.field_label_resolver');
      if (!$field_label_resolver->isFieldGroupable($group_field)) {
        return;
      }
      // Get field definition to determine proper configuration.
      $entity_field_manager = \Drupal::service('entity_field.manager');
      $field_definitions = $entity_field_manager->getFieldDefinitions('user', 'user');

      if (isset($field_definitions[$group_field])) {
        $field_definition = $field_definitions[$group_field];
        $label = (string) $field_definition->getLabel();
        $field_type = $field_definition->getType();

        // Determine the correct table and plugin for the field.
        $table = 'users_field_data';
        $plugin_id = 'standard';

        if (str_starts_with($group_field, 'field_')) {
          $table = 'user__' . $group_field;
          $plugin_id = 'field';
        }
        elseif ($group_field === 'langcode' || $field_type === 'language') {
          $plugin_id = 'language';
        }

        // Build field handler configuration with all required options.
        $field_config = [
          'id' => $group_field,
          'table' => $table,
          'field' => $group_field,
          'relationship' => 'none',
          'group_type' => 'group',
          'admin_label' => '',
          'plugin_id' => $plugin_id,
          'label' => $label,
          'exclude' => FALSE,
          'alter' => [
            'alter_text' => FALSE,
            'text' => '',
            'make_link' => FALSE,
            'path' => '',
            'absolute' => FALSE,
            'external' => FALSE,
            'replace_spaces' => FALSE,
            'path_case' => 'none',
            'trim_whitespace' => FALSE,
            'alt' => '',
            'rel' => '',
            'link_class' => '',
            'prefix' => '',
            'suffix' => '',
            'target' => '',
            'nl2br' => FALSE,
            'max_length' => 0,
            'word_boundary' => TRUE,
            'ellipsis' => TRUE,
            'more_link' => FALSE,
            'more_link_text' => '',
            'more_link_path' => '',
            'strip_tags' => FALSE,
            'trim' => FALSE,
            'preserve_tags' => '',
            'html' => FALSE,
          ],
          'element_type' => '',
          'element_class' => '',
          'element_label_type' => '',
          'element_label_class' => '',
          'element_label_colon' => TRUE,
          'element_wrapper_type' => '',
          'element_wrapper_class' => '',
          'element_default_classes' => TRUE,
          'empty' => '',
          'hide_empty' => FALSE,
          'empty_zero' => FALSE,
          'hide_alter_empty' => TRUE,
        ];

        // Add the selected field to the view as the first field.
        // The D3Chart plugin will automatically detect it as label_field.
        $view->addHandler($display_id, 'field', $table, $group_field, $field_config, 0);
      }
    }
  }
}

/**
 * Implements hook_views_post_render().
 */
function users_metrics_views_post_render(ViewExecutable $view, &$output, $cache) {
  // Build custom table for table_by_field display using query results.
  if ($view->id() !== 'users_metrics_registrations') {
    return;
  }
  if ($view->current_display !== 'table_by_field') {
    return;
  }

  $group_field = \Drupal::request()->query->get('group_field', '');
  if (empty($group_field)) {
    return;
  }

  // Validate that the field is groupable.
  /** @var \Drupal\users_metrics\Service\FieldLabelResolver $field_label_resolver */
  $field_label_resolver = \Drupal::service('users_metrics.field_label_resolver');
  if (!$field_label_resolver->isFieldGroupable($group_field)) {
    return;
  }

  // Get field label.
  $entity_field_manager = \Drupal::service('entity_field.manager');
  $field_definitions = $entity_field_manager->getFieldDefinitions('user', 'user');
  $field_label = isset($field_definitions[$group_field])
    ? (string) $field_definitions[$group_field]->getLabel()
    : $group_field;

  // Build table rows from query results.
  /** @var \Drupal\users_metrics\Service\FieldLabelResolver $field_label_resolver */
  $field_label_resolver = \Drupal::service('users_metrics.field_label_resolver');

  $rows = [];
  foreach ($view->result as $row) {
    // Get the field value from the query result.
    $field_value = $row->{$group_field} ?? '';

    // Get the label for the value (for list fields, language, etc.).
    $display_value = $field_label_resolver->resolveLabel($group_field, $field_value);

    // Get the count value.
    $count = $row->uid ?? $row->uid_count ?? 0;

    $rows[] = [
      'field_value' => $display_value,
      'count' => (int) $count,
    ];
  }

  // Sort by count descending.
  usort($rows, fn($a, $b) => $b['count'] - $a['count']);

  // Build the table render array.
  $table = [
    '#type' => 'table',
    '#header' => [
      ['data' => $field_label, 'field' => 'field_value'],
      ['data' => t('Registrations'), 'field' => 'count'],
    ],
    '#rows' => [],
    '#empty' => t('No data available.'),
    '#attributes' => ['class' => ['users-metrics-by-field-table']],
  ];

  foreach ($rows as $row) {
    $table['#rows'][] = [
      $row['field_value'],
      number_format($row['count']),
    ];
  }

  // Replace the output with our custom table.
  $output = [
    '#type' => 'container',
    '#attributes' => ['class' => ['users-metrics-table-wrapper']],
    'header' => [
      '#markup' => '<h3>' . t('Totals by field') . '</h3>',
    ],
    'table' => $table,
  ];
}

/**
 * Implements hook_views_query_alter().
 */
function users_metrics_views_query_alter(ViewExecutable $view, QueryPluginBase $query) {
  $view_ids = ['users_metrics_registrations', 'users_metrics_logins'];

  if (!in_array($view->id(), $view_ids)) {
    return;
  }

  // Handle dynamic field grouping for the by-field displays.
  $by_field_displays = ['page_by_field', 'table_by_field'];
  if ($view->id() === 'users_metrics_registrations' && in_array($view->current_display, $by_field_displays)) {
    $group_field = \Drupal::request()->query->get('group_field', '');

    if (!empty($group_field)) {
      // Validate that the field is groupable.
      /** @var \Drupal\users_metrics\Service\FieldLabelResolver $field_label_resolver */
      $field_label_resolver = \Drupal::service('users_metrics.field_label_resolver');
      if (!$field_label_resolver->isFieldGroupable($group_field)) {
        return;
      }
      // Determine the correct table for the field.
      $table = 'users_field_data';
      $field_column = $group_field;

      if (str_starts_with($group_field, 'field_')) {
        $table = 'user__' . $group_field;
        $field_column = $group_field . '_value';
        // Ensure the field table is joined.
        $query->ensureTable($table);
      }

      // Add the field to the GROUP BY clause.
      $query->addGroupBy("$table.$field_column");

      // Also add the field to SELECT so it can be used in the results.
      $query->addField($table, $field_column, $group_field);

      // For the table attachment, remove date grouping to show totals by field.
      if ($view->current_display === 'table_by_field') {
        // Remove the date field from GROUP BY to aggregate all dates.
        // Access the groupby property directly since there's no getter method.
        if (property_exists($query, 'groupby') && is_array($query->groupby)) {
          foreach ($query->groupby as $key => $value) {
            if (str_contains($key, 'created')) {
              unset($query->groupby[$key]);
            }
          }
        }

        // Remove date field from ORDER BY if present. The table style
        // already sorts by count (uid) DESC via its configuration.
        if (property_exists($query, 'orderby') && is_array($query->orderby)) {
          foreach ($query->orderby as $key => $value) {
            if (isset($value['field']) && str_contains($value['field'], 'created')) {
              unset($query->orderby[$key]);
            }
          }
        }
      }
    }
  }

  /** @var \Drupal\users_metrics\Service\UserExclusionService $exclusion_service */
  $exclusion_service = \Drupal::service('users_metrics.user_exclusion');
  $excluded_uids = $exclusion_service->getAllExcludedUids();

  if (empty($excluded_uids)) {
    return;
  }

  // Determine table alias based on view.
  $table_alias = $view->id() === 'users_metrics_logins' ? 'watchdog' : 'users_field_data';
  $query->addWhere(0, "$table_alias.uid", $excluded_uids, 'NOT IN');
}

/**
 * Implements hook_preprocess_views_view().
 */
function users_metrics_preprocess_views_view(&$variables) {
  $view = $variables['view'];
  $view_id = $view->id();

  // Only process our metrics views on page displays.
  $target_views = [
    'users_metrics_registrations' => [
      'display' => 'page_registrations',
      'label' => t('registrations'),
      'value_field' => 'uid',
    ],
    'users_metrics_logins' => [
      'display' => 'page_logins',
      'label' => t('logins'),
      'value_field' => 'wid',
    ],
  ];

  if (!isset($target_views[$view_id])) {
    return;
  }

  // Add cache metadata.
  $variables['#cache']['tags'][] = 'config:users_metrics.settings';
  $variables['#cache']['tags'][] = 'config:user.role.list';
  $variables['#cache']['contexts'][] = 'url.query_args';
  $variables['#cache']['contexts'][] = 'user.permissions';

  $config = $target_views[$view_id];

  // Only on the page display, not on attachments.
  if ($view->current_display !== $config['display']) {
    return;
  }

  // Calculate summary statistics from results.
  $results = $view->result;
  if (empty($results)) {
    return;
  }

  $total = 0;
  $peak_value = 0;
  $peak_date = NULL;
  $values = [];

  foreach ($results as $row) {
    // Get the count value from the row.
    $value = 0;
    if (isset($row->{$config['value_field']})) {
      $value = (int) $row->{$config['value_field']};
    }
    elseif (isset($row->uid_count)) {
      $value = (int) $row->uid_count;
    }
    elseif (isset($row->wid_count)) {
      $value = (int) $row->wid_count;
    }

    $total += $value;
    $values[] = $value;

    if ($value > $peak_value) {
      $peak_value = $value;
      // Try to get the date from the row.
      if (isset($row->users_field_data_created_grouped)) {
        $peak_date = $row->users_field_data_created_grouped;
      }
      elseif (isset($row->watchdog_timestamp_grouped)) {
        $peak_date = $row->watchdog_timestamp_grouped;
      }
    }
  }

  $period_days = count($results);
  $daily_avg = $period_days > 0 ? round($total / $period_days, 1) : 0;

  // Build the summary cards render array.
  $summary_cards = [
    '#theme' => 'users_metrics_summary_cards',
    '#total' => $total,
    '#daily_avg' => $daily_avg,
    '#peak_date' => $peak_date,
    '#peak_value' => $peak_value,
    '#period_days' => $period_days,
    '#metric_label' => $config['label'],
    '#attached' => [
      'library' => ['users_metrics/summary_cards'],
    ],
  ];

  // Prepend summary cards to the header.
  if (!isset($variables['header'])) {
    $variables['header'] = [];
  }

  // Add summary cards at the beginning.
  $variables['header'] = [
    'summary_cards' => $summary_cards,
  ] + $variables['header'];
}
