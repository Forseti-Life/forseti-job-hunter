<?php

/**
 * @file
 * Install schema for Copilot Agent Tracker.
 */

/**
 * Implements hook_schema().
 */
function copilot_agent_tracker_schema(): array {
  $schema['copilot_agent_tracker_agents'] = [
    'description' => 'Tracks Copilot agent status and last-seen timestamps.',
    'fields' => [
      'agent_id' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
      ],
      'role' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => FALSE,
      ],
      'website' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => FALSE,
      ],
      'module' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => FALSE,
      ],
      'status' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => 'active',
      ],
      'current_action' => [
        'type' => 'varchar',
        'length' => 512,
        'not null' => FALSE,
      ],
      'last_seen' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'metadata' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
        'description' => 'Arbitrary JSON metadata (sanitized, no secrets).',
      ],
    ],
    'primary key' => ['agent_id'],
    'indexes' => [
      'last_seen' => ['last_seen'],
      'website' => ['website'],
      'module' => ['module'],
    ],
  ];

  $schema['copilot_agent_tracker_events'] = [
    'description' => 'Append-only agent event stream (high-level status, no raw chat logs).',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'agent_id' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
      ],
      'session_id' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => FALSE,
      ],
      'work_item_id' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => FALSE,
      ],
      'website' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => FALSE,
      ],
      'module' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => FALSE,
      ],
      'action' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
      ],
      'status' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => FALSE,
      ],
      'summary' => [
        'type' => 'text',
        'not null' => TRUE,
      ],
      'details' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'agent_id' => ['agent_id'],
      'session_id' => ['session_id'],
      'work_item_id' => ['work_item_id'],
      'created' => ['created'],
    ],
  ];

  $schema['copilot_agent_tracker_replies'] = [
    'description' => 'CEO/operator replies entered in Drupal UI to be consumed by HQ.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'to_agent_id' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
      ],
      'in_reply_to' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
      ],
      'message' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => TRUE,
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'consumed' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'consumed_at' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'hq_item_id' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'description' => 'HQ inbox item id created from this row (set by HQ consumer).',
      ],
      'dismissed' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'dismissed_at' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'dismissed_by_uid' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'consumed' => ['consumed'],
      'to_agent_id' => ['to_agent_id'],
      'created' => ['created'],
      'hq_item_id' => ['hq_item_id'],
      'dismissed' => ['dismissed'],
    ],
  ];

  $schema['copilot_agent_tracker_inbox_resolutions'] = [
    'description' => 'Tracks which CEO inbox items have been resolved/dismissed in Drupal UI.',
    'fields' => [
      'item_id' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
      ],
      'resolved' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'resolved_at' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'resolved_by_uid' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['item_id'],
    'indexes' => [
      'resolved' => ['resolved'],
      'resolved_at' => ['resolved_at'],
    ],
  ];

  return $schema;
}

/**
 * Implements hook_uninstall().
 */
function copilot_agent_tracker_uninstall(): void {
  $db = \Drupal::database();
  $schema = $db->schema();
  foreach ([
    'copilot_agent_tracker_agents',
    'copilot_agent_tracker_events',
    'copilot_agent_tracker_replies',
    'copilot_agent_tracker_inbox_resolutions',
  ] as $table) {
    if ($schema->tableExists($table)) {
      $schema->dropTable($table);
    }
  }
  \Drupal::state()->delete('copilot_agent_tracker.telemetry_token');
}

/**
 * Implements hook_install().
 */
function copilot_agent_tracker_install(): void {
  // Generate an internal telemetry token stored in state (not in git).
  // This allows non-browser senders (e.g. HQ scripts) to post sanitized events.
  $state = \Drupal::state();
  if (!$state->get('copilot_agent_tracker.telemetry_token')) {
    $token = \Drupal\Component\Utility\Crypt::randomBytesBase64(32);
    $state->set('copilot_agent_tracker.telemetry_token', $token);
  }
}

/**
 * Create replies table for UI->HQ responses.
 */
function copilot_agent_tracker_update_8001(): void {
  $schema = copilot_agent_tracker_schema();
  $spec = $schema['copilot_agent_tracker_replies'] ?? NULL;
  if (!$spec) {
    return;
  }
  $db = \Drupal::database();
  $schema_handler = $db->schema();
  if (!$schema_handler->tableExists('copilot_agent_tracker_replies')) {
    $schema_handler->createTable('copilot_agent_tracker_replies', $spec);
  }
}

/**
 * Create inbox resolution table for immediate UI dismissal.
 */
function copilot_agent_tracker_update_8002(): void {
  $schema = copilot_agent_tracker_schema();
  $spec = $schema['copilot_agent_tracker_inbox_resolutions'] ?? NULL;
  if (!$spec) {
    return;
  }
  $db = \Drupal::database();
  $schema_handler = $db->schema();
  if (!$schema_handler->tableExists('copilot_agent_tracker_inbox_resolutions')) {
    $schema_handler->createTable('copilot_agent_tracker_inbox_resolutions', $spec);
  }
}

/**
 * Add hq_item_id to replies for sent-message tracking.
 */
function copilot_agent_tracker_update_8003(): void {
  $db = \Drupal::database();
  $schema_handler = $db->schema();
  if (!$schema_handler->tableExists('copilot_agent_tracker_replies')) {
    return;
  }
  if ($schema_handler->fieldExists('copilot_agent_tracker_replies', 'hq_item_id')) {
    return;
  }
  $schema = copilot_agent_tracker_schema();
  $spec = $schema['copilot_agent_tracker_replies']['fields']['hq_item_id'] ?? NULL;
  if ($spec) {
    $schema_handler->addField('copilot_agent_tracker_replies', 'hq_item_id', $spec);
  }
}

/**
 * Add dismissed fields to sent-replies so operators can hide completed threads.
 */
function copilot_agent_tracker_update_8004(): void {
  $db = \Drupal::database();
  $schema_handler = $db->schema();
  if (!$schema_handler->tableExists('copilot_agent_tracker_replies')) {
    return;
  }

  $schema = copilot_agent_tracker_schema();
  foreach (['dismissed', 'dismissed_at', 'dismissed_by_uid'] as $field) {
    if ($schema_handler->fieldExists('copilot_agent_tracker_replies', $field)) {
      continue;
    }
    $spec = $schema['copilot_agent_tracker_replies']['fields'][$field] ?? NULL;
    if ($spec) {
      $schema_handler->addField('copilot_agent_tracker_replies', $field, $spec);
    }
  }
}

/**
 * Backfill core tracker tables for existing installs.
 */
function copilot_agent_tracker_update_8005(): void {
  $schema = copilot_agent_tracker_schema();
  $db = \Drupal::database();
  $schema_handler = $db->schema();

  foreach (['copilot_agent_tracker_agents', 'copilot_agent_tracker_events'] as $table) {
    if ($schema_handler->tableExists($table)) {
      continue;
    }
    $spec = $schema[$table] ?? NULL;
    if ($spec) {
      $schema_handler->createTable($table, $spec);
    }
  }
}

/**
 * Expand current_action column to varchar(512) to match input validation AC.
 */
function copilot_agent_tracker_update_8006(): void {
  $db = \Drupal::database();
  $schema_handler = $db->schema();

  if ($schema_handler->tableExists('copilot_agent_tracker_agents')
    && $schema_handler->fieldExists('copilot_agent_tracker_agents', 'current_action')) {
    $schema_handler->changeField('copilot_agent_tracker_agents', 'current_action', 'current_action', [
      'type' => 'varchar',
      'length' => 512,
      'not null' => FALSE,
    ]);
  }
}
