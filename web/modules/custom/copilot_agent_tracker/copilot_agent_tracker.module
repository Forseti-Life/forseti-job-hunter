<?php

/**
 * @file
 * Copilot Agent Tracker module.
 */

/**
 * Implements hook_cron().
 *
 * Purge audit log entries older than 30 days.
 */
function copilot_agent_tracker_cron(): void {
  $retentionDays = 30;
  $cutoff = \Drupal::time()->getRequestTime() - ($retentionDays * 86400);

  try {
    $deleted = \Drupal::database()
      ->delete('copilot_agent_tracker_audit')
      ->condition('timestamp', $cutoff, '<')
      ->execute();

    if ($deleted > 0) {
      \Drupal::logger('copilot_agent_tracker')
        ->info('Purged @count audit entries older than @days days.', [
          '@count' => $deleted,
          '@days' => $retentionDays,
        ]);
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('copilot_agent_tracker')
      ->error('Audit log cleanup failed: @error', [
        '@error' => $e->getMessage(),
      ]);
  }
}
