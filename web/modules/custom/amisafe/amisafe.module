<?php

/**
 * @file
 * Contains amisafe.module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function amisafe_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.amisafe':
      return '<p>' . t('Am I Safe? dashboard provides real-time safety monitoring and crime analytics.') . '</p>';
  }
}

/**
 * Implements hook_theme().
 */
function amisafe_theme() {
  return [
    'amisafe_dashboard' => [
      'variables' => [
        'dashboard_data' => NULL,
      ],
      'template' => 'amisafe-dashboard',
    ],
    'amisafe_crime_map' => [
      'variables' => [
        'map_config' => NULL,
        'crime_types' => [],
        'districts' => [],
        'date_range' => NULL,
        'citywide_stats' => [],
      ],
      'template' => 'amisafe-crime-map',
    ],
    'amisafe_mobile_download' => [
      'variables' => [
        'apk_url' => NULL,
        'ipa_url' => NULL,
        'apk_size' => NULL,
        'ipa_size' => NULL,
      ],
      'template' => 'amisafe-mobile-download',
    ],
    'amisafe_log_management' => [
      'variables' => [
        'logs' => [],
      ],
      'template' => 'amisafe-log-management',
    ],
  ];
}