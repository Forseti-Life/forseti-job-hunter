<div class="amisafe-mobile-download">
  <div class="download-header">
    <div class="app-icon"><img src="/themes/custom/forseti/images/logos/originals/forseti_safe.png" alt="Forseti Mobile" class="app-logo"></div>
    <h1>Download Forseti Mobile App</h1>
    <p class="tagline">Stay Informed, Stay Safe</p>
    <div class="development-notice" style="background: #4caf50; color: #ffffff; padding: 15px; border-radius: 8px; margin: 20px 0; text-align: center;">
      <strong>✅ Beta Version Available Now!</strong><br>
      Version 1.0.2 - Beta testing with production authentication and real-time safety alerts
    </div>
  </div>

  <div class="download-section">
    <div class="platform-card android">
      <div class="platform-icon"><img src="/themes/custom/forseti/images/logos/originals/forseti_energized.png" alt="Android" class="platform-logo"></div>
      <h2>Android</h2>
      <p>Beta v1.0.2 - Production Ready</p>
      <a href="https://forseti.life/sites/default/files/forseti/mobile/Forseti-latest.apk" class="download-button android-button" download>
        <span class="button-icon">⬇</span>
        Download APK
        <span class="file-size">(~26 MB)</span>
      </a>
      
      <div class="install-instructions">
        <h3>Installation Steps:</h3>
        <ol>
          <li>Download the APK file</li>
          <li>Open the downloaded file</li>
          <li>Allow "Install from Unknown Sources" if prompted</li>
          <li>Follow the installation wizard</li>
          <li>Create an account to access all features</li>
        </ol>
        
        <div class="production-notice" style="background: #e8f5e9; color: #2e7d32; padding: 10px; border-radius: 4px; margin-top: 10px; font-size: 0.9em;">
          <strong>✨ What's New:</strong><br>
          • Production authentication with user accounts<br>
          • Enhanced error handling and feedback<br>
          • Real-time safety alerts<br>
          • Location-based crime data
        </div>
      </div>
    </div>

    <div class="platform-card ios">
      <div class="platform-icon"><img src="/themes/custom/forseti/images/logos/originals/forseti_capable.png" alt="iOS" class="platform-logo"></div>
      <h2>iOS / iPhone</h2>
      <p>Version 1.0.0</p>
      {% if ipa_url %}
        <a href="{{ ipa_url }}" class="download-button ios-button" download>
          <span class="button-icon">⬇</span>
          Download IPA
          <span class="file-size">({{ ipa_size }})</span>
        </a>
        <div class="install-instructions">
          <h3>Installation Steps:</h3>
          <ol>
            <li>Download the IPA file</li>
            <li>Install using AltStore, Sideloadly, or TestFlight</li>
            <li>Trust the developer certificate in Settings</li>
            <li>Open AmISafe from your home screen</li>
          </ol>
        </div>
      {% else %}
        <div class="unavailable">
          <p>iOS version coming soon</p>
          <p class="note">Will be available on the App Store</p>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="features-section">
    <h2>Current Features</h2>
    <div class="features-grid">
      <div class="feature">
        <span class="feature-icon">👤</span>
        <h3>User Accounts</h3>
        <p>Create your account and login with production authentication</p>
      </div>
      <div class="feature">
        <span class="feature-icon">📍</span>
        <h3>Real-Time Location Tracking</h3>
        <p>H3 Level 13 precision (44m² accuracy)</p>
      </div>
      <div class="feature">
        <span class="feature-icon">🗺️</span>
        <h3>Interactive Crime Map</h3>
        <p>Visualize crime data with hexagonal overlays</p>
      </div>
      <div class="feature">
        <span class="feature-icon">🔔</span>
        <h3>Safety Alerts</h3>
        <p>Get notified when entering high-risk areas</p>
      </div>
      <div class="feature">
        <span class="feature-icon">📊</span>
        <h3>Crime Analytics</h3>
        <p>View statistics and trends for your area</p>
      </div>
      <div class="feature">
        <span class="feature-icon">🔒</span>
        <h3>Privacy First</h3>
        <p>Secure authentication and encrypted data</p>
      </div>
    </div>
  </div>

  <div class="system-requirements">
    <h3>System Requirements</h3>
    <div class="requirements-grid">
      <div class="requirement">
        <strong>Android:</strong> 7.0 (API 24) or higher
      </div>
      <div class="requirement">
        <strong>iOS:</strong> Coming soon
      </div>
      <div class="requirement">
        <strong>Storage:</strong> ~30 MB free space
      </div>
      <div class="requirement">
        <strong>Internet:</strong> Required for real-time data
      </div>
    </div>
  </div>

  <div class="beta-info" style="background: #fff3e0; padding: 20px; border-radius: 8px; margin: 20px 0;">
    <h3 style="margin-top: 0; color: #e65100;">Beta Testing Information</h3>
    <p>This is a beta version. Please report any issues or feedback to help us improve the app.</p>
    <ul>
      <li><strong>Version:</strong> 1.0.2 Beta</li>
      <li><strong>Release Date:</strong> January 2025</li>
      <li><strong>File Size:</strong> ~26 MB</li>
      <li><strong>Status:</strong> Beta testing with production authentication</li>
    </ul>
    <p>Note: You must create an account to use all features. Demo mode is no longer the default behavior.</p>
  </div>

  <div class="support-section">
    <p>Need help? <a href="/contact">Contact us</a></p>
  </div>
</div>
