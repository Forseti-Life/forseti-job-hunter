{#
/**
 * @file
 * Theme implementation to display an evaluated_entity node.
 *
 * Available variables:
 * - node: The node entity with access to the field values.
 * - evaluation_data: Preprocessed evaluation data with organized dimensions.
 * - url: Direct URL of the current node.
 * - label: Label for the node (entity name).
 * - view_mode: View mode; for example, "full" or "teaser".
 *
 * @see template_preprocess_node()
 * @see agent_evaluation_preprocess_node()
 */
#}
{{ attach_library('agent_evaluation/evaluated-entity') }}

<div class="container py-3 evaluated-entity-node">
  <div class="row">
    <div class="col-lg-10 mx-auto">
      
      {# Page header #}
      <div class="text-center mb-4">
        <h1 class="mb-3 text-cyan">{{ label }}</h1>
        
        {# Entity Category #}
        {% if node.field_entity_category.value %}
          <div class="mb-3">
            <span class="badge bg-primary" style="font-size: 1rem; padding: 0.4rem 0.8rem;">
              <i class="fas fa-tag"></i> {{ node.field_entity_category.value|replace({'_': ' '})|title }}
            </span>
          </div>
        {% endif %}
        
        {% if evaluation_data.total_power is not null %}
          <div class="d-inline-block">
            <span class="badge bg-{{ evaluation_data.total_power_level <= 2 ? 'danger' : (evaluation_data.total_power_level <= 5 ? 'warning' : (evaluation_data.total_power_level <= 7 ? 'info' : 'success')) }}" style="font-size: 1.5rem; padding: 0.5rem 1rem;">
              Total Power: {{ evaluation_data.total_power }}/9
            </span>
          </div>
        {% endif %}
      </div>

      {% if evaluation_data.source_conversation %}
        <div class="text-center mb-4">
          <a href="{{ evaluation_data.source_conversation.url }}" class="btn btn-outline-primary">
            <i class="fas fa-comments"></i> View Evaluation Conversation
          </a>
        </div>
      {% endif %}

      {# Main 5 Dimensions Summary #}
      {% if evaluation_data.dimensions %}
        {% set dimensions_by_label = {} %}
        {% for dimension in evaluation_data.dimensions %}
          {% set dimensions_by_label = dimensions_by_label|merge({(dimension.label): dimension}) %}
        {% endfor %}
        
        <div class="row g-2 mb-4">
          {% if dimensions_by_label['Information Access'] is defined %}
            {% set dim = dimensions_by_label['Information Access'] %}
            <div class="col-md-4">
              <div class="p-2 rounded" style="background: rgba(0, 212, 255, 0.1);">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="small text-cyan"><i class="fas fa-database me-1"></i>Info Access</span>
                  <span class="badge bg-{% if dim.score >= 8 %}success{% elseif dim.score >= 6 %}info{% elseif dim.score >= 4 %}warning{% else %}secondary{% endif %}">
                    {{ dim.score }}/9
                  </span>
                </div>
              </div>
            </div>
          {% endif %}
          {% if dimensions_by_label['Resource Control'] is defined %}
            {% set dim = dimensions_by_label['Resource Control'] %}
            <div class="col-md-4">
              <div class="p-2 rounded" style="background: rgba(76, 175, 80, 0.1);">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="small text-success"><i class="fas fa-coins me-1"></i>Resources</span>
                  <span class="badge bg-{% if dim.score >= 8 %}success{% elseif dim.score >= 6 %}info{% elseif dim.score >= 4 %}warning{% else %}secondary{% endif %}">
                    {{ dim.score }}/9
                  </span>
                </div>
              </div>
            </div>
          {% endif %}
          {% if dimensions_by_label['Authority & Permission'] is defined %}
            {% set dim = dimensions_by_label['Authority & Permission'] %}
            <div class="col-md-4">
              <div class="p-2 rounded" style="background: rgba(233, 30, 99, 0.1);">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="small text-danger"><i class="fas fa-gavel me-1"></i>Authority</span>
                  <span class="badge bg-{% if dim.score >= 8 %}success{% elseif dim.score >= 6 %}info{% elseif dim.score >= 4 %}warning{% else %}secondary{% endif %}">
                    {{ dim.score }}/9
                  </span>
                </div>
              </div>
            </div>
          {% endif %}
          {% if dimensions_by_label['Network Position'] is defined %}
            {% set dim = dimensions_by_label['Network Position'] %}
            <div class="col-md-6">
              <div class="p-2 rounded" style="background: rgba(156, 39, 176, 0.1);">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="small text-purple"><i class="fas fa-project-diagram me-1"></i>Network</span>
                  <span class="badge bg-{% if dim.score >= 8 %}success{% elseif dim.score >= 6 %}info{% elseif dim.score >= 4 %}warning{% else %}secondary{% endif %}">
                    {{ dim.score }}/9
                  </span>
                </div>
              </div>
            </div>
          {% endif %}
          {% if dimensions_by_label['Synthesis & Application'] is defined %}
            {% set dim = dimensions_by_label['Synthesis & Application'] %}
            <div class="col-md-6">
              <div class="p-2 rounded" style="background: rgba(255, 235, 59, 0.1);">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="small text-warning"><i class="fas fa-brain me-1"></i>Synthesis</span>
                  <span class="badge bg-{% if dim.score >= 8 %}success{% elseif dim.score >= 6 %}info{% elseif dim.score >= 4 %}warning{% else %}secondary{% endif %}">
                    {{ dim.score }}/9
                  </span>
                </div>
              </div>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# Single nested accordion for all 30 sub-dimensions (matching US Government page) #}
      {% if evaluation_data.dimensions %}
        <div class="accordion accordion-forseti mt-3 mb-5" id="subdimensionsAccordion">
          <div class="accordion-item">
            <h2 class="accordion-header" id="subdim-heading-all">
              <button class="accordion-button collapsed subdim-collapse" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-subdim-all" aria-expanded="false" aria-controls="collapse-subdim-all" aria-labelledby="subdim-heading-all">
                <i class="fas fa-list-ul me-2"></i>View 30 Sub-Dimensions Breakdown
              </button>
            </h2>
            <div id="collapse-subdim-all" class="accordion-collapse collapse" aria-labelledby="subdim-heading-all">
              <div class="accordion-body">
                
                {% for dimension in evaluation_data.dimensions %}
                  {# Map dimension labels to icons and colors #}
                  {% if dimension.label == 'Information Access' %}
                    {% set dim_icon = 'fa-database' %}
                    {% set dim_color = 'cyan' %}
                  {% elseif dimension.label == 'Resource Control' %}
                    {% set dim_icon = 'fa-coins' %}
                    {% set dim_color = 'success' %}
                  {% elseif dimension.label == 'Authority & Permission' %}
                    {% set dim_icon = 'fa-gavel' %}
                    {% set dim_color = 'danger' %}
                  {% elseif dimension.label == 'Network Position' %}
                    {% set dim_icon = 'fa-project-diagram' %}
                    {% set dim_color = 'purple' %}
                  {% elseif dimension.label == 'Synthesis & Application' %}
                    {% set dim_icon = 'fa-brain' %}
                    {% set dim_color = 'warning' %}
                  {% endif %}
                  
                  <div class="{{ loop.last ? 'mb-0' : 'mb-3' }}">
                    <h6 class="text-{{ dim_color }} mb-2"><i class="fas {{ dim_icon }} me-2"></i>{{ dimension.label }}</h6>
                    <div class="row g-2 small">
                      {% for sub_dimension in dimension.sub_dimensions %}
                        {% set sub_dimension_id = sub_dimension.label|lower|replace({' ': '-', '&': 'and', '/': '-'})|trim('-') %}
                        <div class="col-md-4" id="subdim-{{ sub_dimension_id }}" data-subdimension="{{ sub_dimension_id }}">
                          <div class="d-flex justify-content-between p-1">
                            <span>{{ sub_dimension.label }}</span>
                            {% if sub_dimension.score is not null %}
                              <span class="badge bg-{% if sub_dimension.score >= 8 %}success{% elseif sub_dimension.score >= 6 %}info{% elseif sub_dimension.score >= 4 %}warning{% else %}secondary{% endif %} rounded-pill">{{ sub_dimension.score }}</span>
                            {% else %}
                              <span class="badge bg-secondary rounded-pill">—</span>
                            {% endif %}
                          </div>
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                  
                {% endfor %}
                
              </div>
            </div>
          </div>
        </div>
      {% endif %}

      {# Power Radar Chart #}
      {% if evaluation_data.dimensions %}
        {# Define custom order for radar chart positions #}
        {% set dimension_order = [
          'Resource Control',
          'Synthesis & Application',
          'Authority & Permission',
          'Network Position',
          'Information Access'
        ] %}
        
        {# Create lookup for dimensions by label #}
        {% set dimensions_by_label = {} %}
        {% for dimension in evaluation_data.dimensions %}
          {% set dimensions_by_label = dimensions_by_label|merge({(dimension.label): dimension}) %}
        {% endfor %}
        
        {% set chart_data = {
          'primary_labels': [],
          'primary_scores': [],
          'primary_keys': [],
          'dimensions': {}
        } %}
        
        {# Build chart data in custom order #}
        {% for label in dimension_order %}
          {% if dimensions_by_label[label] is defined %}
            {% set dimension = dimensions_by_label[label] %}
            {% set dimension_key = dimension.label|lower|replace({' ': '_'}) %}
            {% set chart_data = chart_data|merge({
              'primary_labels': chart_data.primary_labels|merge([dimension.label]),
              'primary_scores': chart_data.primary_scores|merge([dimension.score ?? 0]),
              'primary_keys': chart_data.primary_keys|merge([dimension_key])
            }) %}
            
            {% set sub_data = {
              'labels': [],
              'scores': [],
              'types': [],
              'keys': [],
              'sub_ids': []
            } %}
            
            {# Add all sub-dimensions #}
            {% for sub_dimension in dimension.sub_dimensions %}
              {% set sub_id = sub_dimension.label|lower|replace({' ': '-', '&': 'and', '/': '-'})|trim('-') %}
              {% set sub_data = sub_data|merge({
                'labels': sub_data.labels|merge([sub_dimension.label]),
                'scores': sub_data.scores|merge([sub_dimension.score ?? 0]),
                'types': sub_data.types|merge(['sub']),
                'keys': sub_data.keys|merge([dimension_key]),
                'sub_ids': sub_data.sub_ids|merge([sub_id])
              }) %}
            {% endfor %}
            
            {% set dimensions_obj = chart_data.dimensions %}
            {% set dimensions_obj = dimensions_obj|merge({(dimension_key): sub_data}) %}
            {% set chart_data = chart_data|merge({'dimensions': dimensions_obj}) %}
          {% endif %}
        {% endfor %}
        
        <div class="power-radar-chart mb-5" 
             data-chart='{{ chart_data|json_encode|raw }}'
             data-entity-name="{{ label }}">
          <div class="row">
            <div class="col-md-10 mx-auto">
              <div class="card card-forseti p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <h3 class="text-cyan mb-0">Power Profile</h3>
                  <button class="btn btn-sm btn-cyan chart-reset-btn" style="display: none;">
                    <i class="fas fa-compress"></i> Show Overview
                  </button>
                </div>
                <p class="text-muted-light text-center small mb-3">Click on any dimension to expand and view sub-dimensions</p>
                <canvas id="powerRadarChart" style="max-height: 500px;"></canvas>
              </div>
            </div>
          </div>
        </div>
      {% endif %}

      {% if evaluation_data.all_empty %}
        <div class="alert alert-info-cyan mt-4 text-center">
          <p class="mb-2"><i class="fas fa-hourglass-half"></i> This entity is being evaluated.</p>
          <p class="mb-0">Scores will appear here once the AI completes the evaluation.</p>
          {% if evaluation_data.source_conversation %}
            <a href="{{ evaluation_data.source_conversation.url }}" class="btn btn-primary mt-3">View Evaluation Progress</a>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>
</div>
