<?php

/**
 * @file
 * Install file for AI Conversation module.
 */

use Drupal\node\Entity\NodeType;
use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;

/**
 * Implements hook_install().
 */
function agent_evaluation_install() {
  // Create the evaluated_entity content type if it doesn't exist.
  $entity_type = NodeType::load('evaluated_entity');
  if (!$entity_type) {
    $entity_type = NodeType::create([
      'type' => 'evaluated_entity',
      'name' => 'Evaluated Entity',
      'description' => 'An entity evaluated using the Agent Power Framework with 30 sub-dimensions across 5 main power dimensions.',
      'settings' => [
        'node' => [
          'options' => [
            'status' => TRUE,
            'promote' => FALSE,
            'sticky' => FALSE,
            'revision' => TRUE,
          ],
          'preview' => DRUPAL_DISABLED,
          'submitted' => TRUE,
        ],
      ],
    ]);
    $entity_type->save();
    \Drupal::logger('agent_evaluation')->notice('Created evaluated_entity content type.');
  } else {
    \Drupal::logger('agent_evaluation')->notice('evaluated_entity content type already exists, skipping creation.');
  }

  // Create fields for the evaluated_entity content type.
  _agent_evaluation_create_entity_fields();

  // Set default permissions.
  _agent_evaluation_set_permissions();
}

/**
 * Create fields for the evaluated_entity content type.
 */
function _agent_evaluation_create_entity_fields() {
  // Total power field
  $fields_to_create = [
    'field_total_power' => [
      'type' => 'integer',
      'cardinality' => 1,
      'label' => 'Total Power Level',
      'description' => 'Overall power level (0-9) calculated from all dimensions',
      'default_value' => [['value' => 0]],
      'settings' => ['min' => 0, 'max' => 9],
    ],
    'field_source_conversation' => [
      'type' => 'entity_reference',
      'cardinality' => 1,
      'label' => 'Source Conversation',
      'description' => 'The AI conversation that created this evaluation',
      'settings' => [
        'target_type' => 'node',
        'handler' => 'default:node',
        'handler_settings' => [
          'target_bundles' => ['ai_conversation' => 'ai_conversation'],
        ],
      ],
    ],
  ];

  // 5 Main Dimensions
  $main_dimensions = [
    'field_information_access' => 'Information Access',
    'field_resource_control' => 'Resource Control',
    'field_authority_permission' => 'Authority & Permission',
    'field_network_position' => 'Network Position',
    'field_synthesis_application' => 'Synthesis & Application',
  ];

  foreach ($main_dimensions as $field_name => $label) {
    $fields_to_create[$field_name] = [
      'type' => 'integer',
      'cardinality' => 1,
      'label' => $label,
      'description' => "Power level (0-9) for {$label} dimension",
      'default_value' => [['value' => 0]],
      'settings' => ['min' => 0, 'max' => 9],
    ];
  }

  // 30 Sub-Dimensions (6 per main dimension)
  // Field names must be ≤32 characters
  // Information Access sub-dimensions
  $sub_dimensions = [
    'field_sub_scope' => 'Scope',
    'field_sub_restriction' => 'Restriction',
    'field_sub_classification' => 'Classification',
    'field_sub_temporal' => 'Temporal',
    'field_sub_sources' => 'Sources',
    'field_sub_granularity' => 'Granularity',
    // Resource Control sub-dimensions  
    'field_sub_computational' => 'Computational Resources',
    'field_sub_financial' => 'Financial Capital',
    'field_sub_data_storage' => 'Data Storage',
    'field_sub_network_bandwidth' => 'Network Bandwidth',
    'field_sub_api_access' => 'API Access',
    'field_sub_human' => 'Human Resources',
    // Authority & Permission sub-dimensions
    'field_sub_legal' => 'Legal Authorization',
    'field_sub_institutional' => 'Institutional Backing',
    'field_sub_budget_auth' => 'Budget Authority',
    'field_sub_policy' => 'Policy Compliance',
    'field_sub_override' => 'Override Capability',
    'field_sub_audit' => 'Audit & Accountability',
    // Network Position sub-dimensions
    'field_sub_connectivity' => 'Connectivity',
    'field_sub_centrality' => 'Centrality',
    'field_sub_trust_reputation' => 'Trust & Reputation',
    'field_sub_info_flow' => 'Information Flow Control',
    'field_sub_coalition' => 'Coalition Building',
    'field_sub_network_effects' => 'Network Effects',
    // Synthesis & Application sub-dimensions
    'field_sub_reasoning' => 'Reasoning',
    'field_sub_creativity' => 'Creativity',
    'field_sub_planning' => 'Planning',
    'field_sub_learning' => 'Learning',
    'field_sub_memory' => 'Memory',
    'field_sub_execution' => 'Execution',
  ];

  foreach ($sub_dimensions as $field_name => $label) {
    $fields_to_create[$field_name] = [
      'type' => 'integer',
      'cardinality' => 1,
      'label' => $label,
      'description' => "Sub-dimension power level (0-9) for {$label}",
      'default_value' => [['value' => 0]],
      'settings' => ['min' => 0, 'max' => 9],
    ];
    
    // Also create description field for this sub-dimension
    $desc_field_name = $field_name . '_desc';
    $fields_to_create[$desc_field_name] = [
      'type' => 'text_long',
      'cardinality' => 1,
      'label' => $label . ' Description',
      'description' => "AI-provided description for {$label} sub-dimension",
      'settings' => [],
    ];
  }

  // Create field storage and field configs
  foreach ($fields_to_create as $field_name => $field_info) {
    // Create field storage if it doesn't exist.
    $field_storage = FieldStorageConfig::loadByName('node', $field_name);
    if (!$field_storage) {
      $field_storage = FieldStorageConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => $field_info['type'],
        'cardinality' => $field_info['cardinality'],
        'settings' => $field_info['settings'],
      ]);
      $field_storage->save();
    }

    // Create field config if it doesn't exist.
    $field_config = FieldConfig::loadByName('node', 'evaluated_entity', $field_name);
    if (!$field_config) {
      $field_config = FieldConfig::create([
        'field_storage' => $field_storage,
        'bundle' => 'evaluated_entity',
        'label' => $field_info['label'],
        'description' => $field_info['description'],
        'required' => $field_info['required'] ?? FALSE,
        'default_value' => $field_info['default_value'] ?? NULL,
        'settings' => [],
      ]);
      $field_config->save();
    }
  }
}

