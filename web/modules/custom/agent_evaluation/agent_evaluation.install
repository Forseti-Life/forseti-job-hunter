/**
 * Set default permissions for the evaluated_entity content type.
 */
function _agent_evaluation_set_permissions() {
  $role_storage = \Drupal::entityTypeManager()->getStorage('user_role');
  
  // Give authenticated users permission to use AI conversations and view evaluated entities.
  $authenticated_role = $role_storage->load('authenticated');
  if ($authenticated_role) {
    $authenticated_role->grantPermission('use ai conversation');
    $authenticated_role->grantPermission('create evaluated_entity content');
    $authenticated_role->grantPermission('edit own evaluated_entity content');
    $authenticated_role->grantPermission('delete own evaluated_entity content');
    $authenticated_role->save();
  }
  
  // Give administrators full access.
  $admin_role = $role_storage->load('administrator');
  if ($admin_role) {
    $admin_role->grantPermission('use ai conversation');
    $admin_role->grantPermission('administer ai conversation');
    $admin_role->grantPermission('create evaluated_entity content');
    $admin_role->grantPermission('edit any evaluated_entity content');
    $admin_role->grantPermission('delete any evaluated_entity content');
    $admin_role->save();
  }
}

/**
 * Implements hook_uninstall().
 */
function agent_evaluation_uninstall() {
  // Leave the evaluated_entity content type and all data intact.
  // This prevents accidental data loss when the module is disabled.
  
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  
  // Count total evaluated entities for reporting
  $entity_query = $node_storage->getQuery()
    ->condition('type', 'evaluated_entity')
    ->accessCheck(FALSE);
  $total_entities = $entity_query->count()->execute();

  // Remove module-specific configuration only
  $config = \Drupal::configFactory()->getEditable('agent_evaluation.settings');
  if (!$config->isNew()) {
    $config->delete();
    \Drupal::logger('agent_evaluation')->notice('Removed agent_evaluation module settings.');
  }
  
  // Log and inform user
  if ($total_entities > 0) {
    \Drupal::logger('agent_evaluation')->notice('Agent Evaluation module uninstalled. Preserved evaluated_entity content type and @count entities.', ['@count' => $total_entities]);
    \Drupal::messenger()->addStatus(t('Agent Evaluation module uninstalled. The evaluated_entity content type and @count entities have been preserved. To completely remove all data, use: drush php-eval "_agent_evaluation_complete_removal();"', ['@count' => $total_entities]));
  } else {
    \Drupal::logger('agent_evaluation')->notice('Agent Evaluation module uninstalled. No evaluated entities found.');
    \Drupal::messenger()->addStatus(t('Agent Evaluation module uninstalled successfully. The evaluated_entity content type has been preserved.'));
  }
}

/**
 * Helper function to completely remove all agent evaluation data and fields.
 * 
 * WARNING: This will permanently delete all evaluated entity data!
 * Only call this if you're absolutely sure you want to remove all data.
 * 
 * Usage: Run this via drush php-eval:
 * drush php-eval "_agent_evaluation_complete_removal();"
 */
function _agent_evaluation_complete_removal() {
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  
  // Delete all evaluated_entity nodes
  $entity_query = $node_storage->getQuery()
    ->condition('type', 'evaluated_entity')
    ->accessCheck(FALSE);
  $entity_nids = $entity_query->execute();
  
  if (!empty($entity_nids)) {
    $nodes = $node_storage->loadMultiple($entity_nids);
    $node_storage->delete($nodes);
    \Drupal::logger('agent_evaluation')->notice('Deleted @count evaluated entity nodes.', ['@count' => count($entity_nids)]);
  }
  
  // Remove the evaluated_entity content type
  $entity_type = NodeType::load('evaluated_entity');
  if ($entity_type) {
    $entity_type->delete();
    \Drupal::logger('agent_evaluation')->notice('Removed evaluated_entity content type.');
  }
  
  // Get all field names
  $all_fields = [
    'field_total_power',
    'field_information_access',
    'field_resource_control',
    'field_authority_permission',
    'field_network_position',
    'field_synthesis_application',
    'field_sub_scope',
    'field_sub_restriction',
    'field_sub_classification',
    'field_sub_temporal',
    'field_sub_sources',
    'field_sub_granularity',
    'field_sub_computational_resources',
    'field_sub_financial_capital',
    'field_sub_data_storage',
    'field_sub_network_bandwidth',
    'field_sub_api_access',
    'field_sub_human_resources',
    'field_sub_legal_authorization',
    'field_sub_institutional_backing',
    'field_sub_budget_authority',
    'field_sub_policy_compliance',
    'field_sub_override_capability',
    'field_sub_audit_accountability',
    'field_sub_connectivity',
    'field_sub_centrality',
    'field_sub_trust_reputation',
    'field_sub_information_flow',
    'field_sub_coalition_building',
    'field_sub_network_effects',
    'field_sub_reasoning',
    'field_sub_creativity',
    'field_sub_planning',
    'field_sub_learning',
    'field_sub_memory',
    'field_sub_execution',
  ];
  
  foreach ($all_fields as $field_name) {
    // Remove field configuration
    $field_config = FieldConfig::loadByName('node', 'evaluated_entity', $field_name);
    if ($field_config) {
      $field_config->delete();
    }
    
    // Remove field storage (this will delete all data in the field)
    $field_storage = FieldStorageConfig::loadByName('node', $field_name);
    if ($field_storage) {
      $field_storage->delete();
      \Drupal::logger('agent_evaluation')->notice('Removed field storage for @field.', ['@field' => $field_name]);
    }
  }
  
  // Remove module configuration
  \Drupal::configFactory()->getEditable('agent_evaluation.settings')->delete();
  
  \Drupal::messenger()->addStatus(t('Complete Agent Evaluation data removal finished. All evaluation data has been permanently deleted.'));
}

/**
 * Update hook to add summary message count field for existing installations.
 */
function agent_evaluation_update_8003() {
  // Add the summary message count field that's referenced in code but missing from install.
  $field_storage = FieldStorageConfig::loadByName('node', 'field_summary_message_count');
  if (!$field_storage) {
    $field_storage = FieldStorageConfig::create([
      'field_name' => 'field_summary_message_count',
      'entity_type' => 'node',
      'type' => 'integer',
      'cardinality' => 1,
      'settings' => [],
    ]);
    $field_storage->save();
  }

  $field_config = FieldConfig::loadByName('node', 'agent_evaluation', 'field_summary_message_count');
  if (!$field_config) {
    $field_config = FieldConfig::create([
      'field_storage' => $field_storage,
      'bundle' => 'agent_evaluation',
      'label' => 'Summary Message Count',
      'description' => 'Counter for summary frequency logic',
      'required' => FALSE,
      'default_value' => [['value' => 0]],
      'settings' => [],
    ]);
    $field_config->save();
  }

  return t('Added summary message count field to AI conversations.');
}

/**
 * Update system prompt configuration with Forseti AI assistant persona.
 */
function agent_evaluation_update_8005() {
  // Use PromptManager to update to Forseti system prompt
  $prompt_manager = \Drupal::service('agent_evaluation.prompt_manager');
  $prompt_manager->initializeDefaultPrompt();
  
  return t('Updated AI conversation system prompt with Forseti AI assistant persona.');
}

/**
 * Add description fields for sub-dimension scores.
 */
function agent_evaluation_update_8007() {
  $sub_dimension_keys = [
    'scope', 'restriction', 'classification', 'temporal', 'sources', 'granularity',
    'computational', 'financial', 'data_storage', 'network_bandwidth', 'api_access', 'human',
    'legal', 'institutional', 'budget_auth', 'policy', 'override', 'audit',
    'connectivity', 'centrality', 'trust_reputation', 'info_flow', 'coalition', 'network_effects',
    'reasoning', 'creativity', 'planning', 'learning', 'memory', 'execution',
  ];

  $fields_created = 0;
  
  foreach ($sub_dimension_keys as $key) {
    $field_name = 'field_sub_' . $key . '_desc';
    
    // Create field storage if it doesn't exist
    $field_storage = \Drupal\field\Entity\FieldStorageConfig::loadByName('node', $field_name);
    if (!$field_storage) {
      $field_storage = \Drupal\field\Entity\FieldStorageConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => 'text_long',
        'cardinality' => 1,
        'settings' => [],
      ]);
      $field_storage->save();
    }

    // Create field config if it doesn't exist
    $field_config = \Drupal\field\Entity\FieldConfig::loadByName('node', 'evaluated_entity', $field_name);
    if (!$field_config) {
      $field_config = \Drupal\field\Entity\FieldConfig::create([
        'field_storage' => $field_storage,
        'bundle' => 'evaluated_entity',
        'label' => ucwords(str_replace('_', ' ', $key)) . ' Description',
        'description' => 'AI-provided description for ' . $key . ' sub-dimension',
        'required' => FALSE,
        'settings' => [],
      ]);
      $field_config->save();
      $fields_created++;
    }
  }

  return t('Added @count description fields for sub-dimension scores.', ['@count' => $fields_created]);
}