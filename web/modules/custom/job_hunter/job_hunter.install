    ]);
    $messages[] = 'Added external_source column';
  }
  
  // Add external_job_id column
  if (!$schema->fieldExists('jobhunter_job_requirements', 'external_job_id')) {
    $schema->addField('jobhunter_job_requirements', 'external_job_id', [
      'type' => 'varchar',
      'length' => 512,
      'description' => 'External job ID from source system',
    ]);
    $schema->addIndex('jobhunter_job_requirements', 'external_job_id', [['external_job_id', 100]]);
    $messages[] = 'Added external_job_id column';
  }
  
  // Add created_by_user_id column
  if (!$schema->fieldExists('jobhunter_job_requirements', 'created_by_user_id')) {
    $schema->addField('jobhunter_job_requirements', 'created_by_user_id', [
      'type' => 'int',
      'description' => 'User ID who created/imported this job',
    ]);
    $messages[] = 'Added created_by_user_id column';
  }
  
  // Add application_url column
  if (!$schema->fieldExists('jobhunter_job_requirements', 'application_url')) {
    $schema->addField('jobhunter_job_requirements', 'application_url', [
      'type' => 'varchar',
      'length' => 512,
      'description' => 'Direct application URL for the job',
    ]);
    $messages[] = 'Added application_url column';
  }
  
  // Add created_at and updated_at timestamp columns (complement existing created/updated)
  if (!$schema->fieldExists('jobhunter_job_requirements', 'created_at')) {
    $schema->addField('jobhunter_job_requirements', 'created_at', [
      'type' => 'varchar',
      'length' => 50,
      'description' => 'ISO 8601 timestamp when job was created',
    ]);
    $messages[] = 'Added created_at column';
  }
  
  if (!$schema->fieldExists('jobhunter_job_requirements', 'updated_at')) {
    $schema->addField('jobhunter_job_requirements', 'updated_at', [
      'type' => 'varchar',
      'length' => 50,
      'description' => 'ISO 8601 timestamp when job was last updated',
    ]);
    $messages[] = 'Added updated_at column';
  }
  
  if (empty($messages)) {
    return t('No update needed - all columns already exist.');
  }
  
  return t('Updated jobhunter_job_requirements table: @changes', [
    '@changes' => implode(', ', $messages),
  ]);
}

