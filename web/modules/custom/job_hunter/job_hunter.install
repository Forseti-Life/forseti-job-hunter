      'type' => 'varchar',
      'length' => 512,
      'not null' => FALSE,
      'description' => 'Company logo/thumbnail URL.',
    ],
    'share_link' => [
      'type' => 'varchar',
      'length' => 512,
      'not null' => FALSE,
      'description' => 'Google Jobs direct share link.',
    ],
    'work_from_home' => [
      'type' => 'int',
      'size' => 'tiny',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Work from home option available (1=yes, 0=no).',
    ],
    'health_insurance' => [
      'type' => 'int',
      'size' => 'tiny',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Health insurance benefit offered (1=yes, 0=no).',
    ],
    'dental_coverage' => [
      'type' => 'int',
      'size' => 'tiny',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Dental coverage benefit offered (1=yes, 0=no).',
    ],
    'paid_time_off' => [
      'type' => 'int',
      'size' => 'tiny',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Paid time off benefit offered (1=yes, 0=no).',
    ],
    'job_highlights' => [
      'type' => 'text',
      'size' => 'big',
      'not null' => FALSE,
      'description' => 'JSON-encoded structured highlights (qualifications, responsibilities, benefits).',
    ],
    'apply_options' => [
      'type' => 'text',
      'not null' => FALSE,
      'description' => 'JSON-encoded array of application links and options.',
    ],
  ];
  
  // Add each column if it doesn't exist
  foreach ($columns as $column_name => $column_spec) {
    if (!$schema->fieldExists('jobhunter_job_requirements', $column_name)) {
      $schema->addField('jobhunter_job_requirements', $column_name, $column_spec);
      $messages[] = $column_name;
    }
  }
  
  // Add indexes for filterable boolean fields
  if (!$schema->indexExists('jobhunter_job_requirements', 'idx_work_from_home')) {
    $schema->addIndex('jobhunter_job_requirements', 'idx_work_from_home', ['work_from_home'], [
      'fields' => ['work_from_home' => ['type' => 'int', 'size' => 'tiny']],
    ]);
  }
  
  if (!$schema->indexExists('jobhunter_job_requirements', 'idx_health_insurance')) {
    $schema->addIndex('jobhunter_job_requirements', 'idx_health_insurance', ['health_insurance'], [
      'fields' => ['health_insurance' => ['type' => 'int', 'size' => 'tiny']],
    ]);
  }
  
  if (!$schema->indexExists('jobhunter_job_requirements', 'idx_via')) {
    $schema->addIndex('jobhunter_job_requirements', 'idx_via', ['via'], [
      'fields' => ['via' => ['type' => 'varchar', 'length' => 255]],
    ]);
  }
  
  if (!empty($messages)) {
    return t('Added SerpAPI metadata columns: @columns with performance indexes.', [
      '@columns' => implode(', ', $messages),
    ]);
  }
  
  return t('All SerpAPI metadata columns already exist.');
}

