/**
 * Add JSON storage columns to jobhunter_job_requirements for job tailoring workflow.
 */
function job_hunter_update_9002() {
  $schema = \Drupal::database()->schema();
  $messages = [];
  
  if (!$schema->tableExists('jobhunter_job_requirements')) {
    return t('Table jobhunter_job_requirements does not exist.');
  }
  
  $new_fields = [
    'raw_posting_text' => [
      'type' => 'text',
      'size' => 'big',
      'description' => 'Original pasted job posting text',
    ],
    'extracted_json' => [
      'type' => 'text',
      'size' => 'big',
      'description' => 'AI-extracted structured job data',
    ],
    'skills_required_json' => [
      'type' => 'text',
      'size' => 'big',
      'description' => 'Must-have and nice-to-have skills',
    ],
    'keywords_json' => [
      'type' => 'text',
      'size' => 'big',
      'description' => 'Important keywords from posting',
    ],
    'source_platform' => [
      'type' => 'varchar',
      'length' => 100,
      'description' => 'linkedin, indeed, company_site, etc.',
    ],
    'ai_extraction_status' => [
      'type' => 'varchar',
      'length' => 32,
      'default' => 'pending',
      'description' => 'pending, completed, failed',
    ],
  ];
  
  foreach ($new_fields as $field_name => $spec) {
    if (!$schema->fieldExists('jobhunter_job_requirements', $field_name)) {
      $schema->addField('jobhunter_job_requirements', $field_name, $spec);
      $messages[] = $field_name;
    }
  }
  
  if (empty($messages)) {
    return t('No update needed - all JSON columns already exist.');
  }
  
  return t('Added columns to jobhunter_job_requirements: @columns', [
    '@columns' => implode(', ', $messages),
  ]);
}

