      ],
      'external_job_id' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'description' => 'Google job ID (e.g., projects/{project}/companies/{company}/jobs/{job})',
      ],
      'job_title' => [
        'type' => 'varchar',
        'length' => 255,
        'description' => 'Job title from search result',
      ],
      'company_name' => [
        'type' => 'varchar',
        'length' => 255,
        'description' => 'Company name from search result',
      ],
      'location' => [
        'type' => 'varchar',
        'length' => 255,
        'description' => 'Job location',
      ],
      'job_data_json' => [
        'type' => 'text',
        'size' => 'big',
        'description' => 'Complete JSON data of the job from API',
      ],
      'rank_position' => [
        'type' => 'int',
        'description' => 'Position in search results (1-based)',
      ],
      'imported_to_job_id' => [
        'type' => 'int',
        'description' => 'Reference to jobhunter_job_requirements.id if imported',
      ],
      'imported_at' => [
        'type' => 'int',
        'description' => 'Timestamp when job was imported, NULL if not imported',
      ],
      'imported_by_uid' => [
        'type' => 'int',
        'description' => 'User ID who imported this job',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Timestamp when result was stored',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'search_query_id' => ['search_query_id'],
      'external_job_id' => [['external_job_id', 100]],
      'imported_to_job_id' => ['imported_to_job_id'],
      'imported_at' => ['imported_at'],
      'job_title' => [['job_title', 100]],
      'company_name' => [['company_name', 100]],
      'created' => ['created'],
    ],
  ];
  
  $schema->createTable('jobhunter_job_search_results', $table_schema);
}

