function job_hunter_uninstall() {
  $messenger = \Drupal::messenger();
  $logger = \Drupal::logger('job_hunter');
  
  try {
    $logger->info('Uninstalling Job Hunter module...');
    
    // Only remove module configuration - preserve all tables and data
    \Drupal::configFactory()->getEditable('job_hunter.settings')->delete();
    
    $messenger->addStatus(t('Job Hunter module uninstalled. All custom tables and data preserved.'));
    $logger->info('Job Hunter module uninstalled - data preserved.');
    
  }
  catch (\Exception $e) {
    $messenger->addError(t('Error uninstalling Job Hunter module: @error', ['@error' => $e->getMessage()]));
    $logger->error('Uninstallation error: @error', ['@error' => $e->getMessage()]);
  }
}

