/**
 * Migrate jobhunter_contacts schema for release-e contact-referral-tracker.
 *
 * - Renames name → full_name, title → job_title
 * - Drops company_id and email columns
 * - Adds company_name (varchar 255)
 * - Widens referral_status to varchar(20) for 'pending-referral'
 * - Normalizes old referral_status values to 'none'
 */
function job_hunter_update_9055() {
  $schema = \Drupal::database()->schema();
  $db = \Drupal::database();

  // Rename name → full_name.
  if ($schema->fieldExists('jobhunter_contacts', 'name')) {
    $schema->changeField('jobhunter_contacts', 'name', 'full_name', [
      'type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => '',
    ]);
  }

  // Rename title → job_title.
  if ($schema->fieldExists('jobhunter_contacts', 'title')) {
    $schema->changeField('jobhunter_contacts', 'title', 'job_title', [
      'type' => 'varchar', 'length' => 255, 'not null' => FALSE, 'default' => NULL,
    ]);
  }

  // Drop company_id (replaced by free-text company_name).
  if ($schema->fieldExists('jobhunter_contacts', 'company_id')) {
    $schema->dropField('jobhunter_contacts', 'company_id');
  }

  // Drop email (not in release-e schema).
  if ($schema->fieldExists('jobhunter_contacts', 'email')) {
    $schema->dropField('jobhunter_contacts', 'email');
  }

  // Add company_name free-text field.
  if (!$schema->fieldExists('jobhunter_contacts', 'company_name')) {
    $schema->addField('jobhunter_contacts', 'company_name', [
      'type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => '',
    ]);
  }

  // Widen referral_status to varchar(20) to accommodate 'pending-referral'.
  $schema->changeField('jobhunter_contacts', 'referral_status', 'referral_status', [
    'type' => 'varchar', 'length' => 20, 'not null' => TRUE, 'default' => 'none',
  ]);

  // Normalize any stale referral_status values to 'none'.
  $db->update('jobhunter_contacts')
    ->fields(['referral_status' => 'none'])
    ->condition('referral_status', ['none', 'referred', 'pending-referral'], 'NOT IN')
    ->execute();

  return t('Migrated jobhunter_contacts schema for contact-referral-tracker.');
}

/**
 * Create jobhunter_contact_job_links table for contact-to-saved-job referral links.
 */
