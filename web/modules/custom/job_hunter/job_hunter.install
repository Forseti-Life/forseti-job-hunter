/**
 * Add SerpAPI rich metadata columns for enhanced search and filtering.
 */
function job_hunter_update_9024() {
  $database = \Drupal::database();
  $schema = $database->schema();
  $messages = [];
  
  // Define columns to add
  $columns = [
    'via' => [
      'type' => 'varchar',
      'length' => 255,
      'not null' => FALSE,
      'description' => 'Source platform where job was posted (e.g., LinkedIn, Indeed).',
