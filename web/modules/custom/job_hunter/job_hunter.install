<?php

/**
 * @file
 * Install, update and uninstall functions for the Job Hunter module.
 * 
 * DATA PRESERVATION POLICY:
 * This module preserves all custom tables during uninstallation.
 * Only module configuration is removed during uninstall.
 */

/**
 * Implements hook_schema().
 */
function job_hunter_schema() {
  // Custom tables created in hook_install() to prevent auto-deletion
  return [];
}

/**
 * Implements hook_requirements().
 */
function job_hunter_requirements($phase) {
  $requirements = [];
  
  if ($phase === 'uninstall') {
    $requirements['job_hunter_data_preservation'] = [
      'title' => t('Job Hunter - Data Preservation'),
      'value' => t('All custom tables will be preserved'),
      'description' => t('Custom database tables will NOT be deleted during uninstall to prevent data loss. Manual cleanup available via database tools if needed.'),
      'severity' => REQUIREMENT_INFO,
    ];
  }
  
  return $requirements;
}

/**
 * Implements hook_install().
 */
function job_hunter_install() {
  $messenger = \Drupal::messenger();
  $logger = \Drupal::logger('job_hunter');
  
  try {
    $logger->info('Installing Job Hunter module...');
    
    // Create all custom tables
    _job_hunter_create_companies_table();
    _job_hunter_create_job_requirements_table();
    _job_hunter_create_job_seeker_table();
    _job_hunter_create_job_history_table();
    _job_hunter_create_education_history_table();
    _job_hunter_create_resume_parsed_data_table();
    _job_hunter_create_job_seeker_resumes_table();
    _job_hunter_create_tailored_resumes_table();
    _job_hunter_create_cover_letters_table();
    _job_hunter_create_pdf_history_table();
    _job_hunter_create_queue_suspended_table();
    _job_hunter_create_google_jobs_sync_table();
    _job_hunter_create_google_jobs_validation_log_table();
    _job_hunter_create_job_search_queries_table();
    _job_hunter_create_job_search_results_table();
    _job_hunter_create_search_history_table();
    _job_hunter_create_saved_jobs_table();
    _job_hunter_create_applications_table();
     _job_hunter_create_employer_credentials_table();
     _job_hunter_create_interview_notes_table();
     _job_hunter_create_interview_rounds_table();
    _job_hunter_create_saved_searches_table();
    _job_hunter_create_application_notes_table();
    _job_hunter_create_company_interest_table();
    _job_hunter_create_company_research_table();
    _job_hunter_create_contacts_table();
    _job_hunter_create_offers_table();
    
    // Create content types and fields
    _job_hunter_create_error_queue_content_type();
    _job_hunter_create_error_queue_fields();
    
    $messenger->addMessage(t('Job Hunter module installed successfully. Custom database tables and error queue content type created.'));
    $logger->info('Job Hunter module installation completed.');
    
  }
  catch (\Exception $e) {
    $messenger->addError(t('Error installing Job Hunter module: @error', ['@error' => $e->getMessage()]));
    $logger->error('Installation error: @error', ['@error' => $e->getMessage()]);
    throw $e;
  }
}

/**
 * Create jobhunter_saved_jobs table.
 *
 * Stores user-specific saved-job mappings (My Jobs list) separate from the
 * global Forseti jobs catalog in jobhunter_job_requirements.
 */
function _job_hunter_create_saved_jobs_table() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('jobhunter_saved_jobs')) {
    return;
  }

  $table_schema = [
    'description' => 'User-specific saved jobs mapping table.',
    'fields' => [
      'id' => ['type' => 'serial', 'not null' => TRUE],
      'uid' => ['type' => 'int', 'not null' => TRUE, 'default' => 0, 'description' => 'User ID'],
      'job_id' => ['type' => 'int', 'not null' => TRUE, 'description' => 'Job requirement ID'],
      'archived' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Per-user archive flag (1 = archived by this user).',
      ],
      'created' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
      'updated' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'user_job' => ['uid', 'job_id'],
    ],
    'indexes' => [
      'uid' => ['uid'],
      'job_id' => ['job_id'],
      'uid_job' => ['uid', 'job_id'],
    ],
  ];

  $schema->createTable('jobhunter_saved_jobs', $table_schema);
}

/**
 * Create user saved-jobs mapping table.
 */
function job_hunter_update_9026() {
  _job_hunter_create_saved_jobs_table();
  return t('Created jobhunter_saved_jobs table for per-user My Jobs mappings.');
}

/**
 * Create jobhunter_applications table.
 *
 * Tracks job applications and their submission status, enabling automatic
 * submission via browser automation as well as manual tracking.
 */
function _job_hunter_create_applications_table() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('jobhunter_applications')) {
    return;
  }

  $table_schema = [
    'description' => 'Job application tracking and submission history.',
    'fields' => [
      'id' => ['type' => 'serial', 'not null' => TRUE],
      'uid' => ['type' => 'int', 'not null' => TRUE, 'default' => 0, 'description' => 'User ID'],
      'job_id' => ['type' => 'int', 'not null' => TRUE, 'description' => 'Job requirement ID'],
      'tailored_resume_used' => ['type' => 'text', 'description' => 'The tailored resume content used for this application'],
      'submission_status' => [
        'type' => 'varchar',
        'length' => 50,
        'default' => 'pending',
        'description' => 'Status: pending, processing, submitted, failed, manual_required',
      ],
      'submission_method' => [
        'type' => 'varchar',
        'length' => 20,
        'default' => 'auto',
        'description' => 'auto or manual',
      ],
      'submission_date' => ['type' => 'varchar', 'length' => 19, 'description' => 'When application was submitted (YYYY-MM-DD HH:MM:SS)'],
      'confirmation_reference' => [
        'type' => 'varchar',
        'length' => 255,
        'description' => 'Application reference number or confirmation ID from employer',
      ],
      'confirmation_screenshot' => ['type' => 'blob', 'description' => 'Screenshot of confirmation page'],
      'automation_success' => ['type' => 'int', 'default' => 0, 'description' => 'Whether automation succeeded (1=yes)'],
      'admin_review_required' => ['type' => 'int', 'default' => 0, 'description' => 'Whether admin review needed (1=yes)'],
      'error_details' => ['type' => 'text', 'description' => 'JSON details of submission error'],
      'created' => ['type' => 'varchar', 'length' => 19, 'description' => 'Created timestamp (YYYY-MM-DD HH:MM:SS)'],
      'changed' => ['type' => 'varchar', 'length' => 19, 'description' => 'Last updated timestamp (YYYY-MM-DD HH:MM:SS)'],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'uid' => ['uid'],
      'job_id' => ['job_id'],
      'uid_job' => ['uid', 'job_id'],
      'status' => ['submission_status'],
      'admin_review' => ['admin_review_required'],
      'created' => ['created'],
    ],
    'foreign keys' => [
      'uid_fk' => [
        'table' => 'users',
        'columns' => ['uid' => 'uid'],
      ],
    ],
  ];

  $schema->createTable('jobhunter_applications', $table_schema);
}

/**
 * Create applications table on update.
 */
function job_hunter_update_9027() {
  _job_hunter_create_applications_table();
  return t('Created jobhunter_applications table for application tracking and submission.');
}

/**
 * Create jobhunter_employer_credentials table.
 *
 * Securely stores employer site credentials needed for automated job application
 * submission via browser automation. All credentials are encrypted at rest.
 *
 * SECURITY NOTES:
 * - Credentials are encrypted using Drupal's encryption service
 * - Access requires authentication and permission checks
 * - All access is logged (without plaintext credentials)
 * - User can only access their own credentials
 * - Admin can manage credentials for audit purposes
 */
function _job_hunter_create_employer_credentials_table() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('jobhunter_employer_credentials')) {
    return;
  }

  $table_schema = [
    'description' => 'Securely encrypted employer credentials for automated job application submission.',
    'fields' => [
      'id' => ['type' => 'serial', 'not null' => TRUE],
      'uid' => ['type' => 'int', 'not null' => TRUE, 'default' => 0, 'description' => 'User ID'],
      'company_id' => ['type' => 'int', 'not null' => TRUE, 'description' => 'Company/employer ID (jobhunter_companies)'],
      'credential_type' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => 'basic',
        'description' => 'Type: basic (username+password) or api_token',
      ],
      'encrypted_data' => [
        'type' => 'text',
        'size' => 'medium',
        'not null' => TRUE,
        'description' => 'Base64-encoded encrypted credential data (JSON)',
      ],
      'submission_url' => [
        'type' => 'varchar',
        'length' => 512,
        'description' => 'URL where these credentials are used (e.g., ATS login page)',
      ],
      'created' => [
        'type' => 'varchar',
        'length' => 19,
        'not null' => TRUE,
        'description' => 'Created timestamp (YYYY-MM-DD HH:MM:SS)',
      ],
      'updated' => [
        'type' => 'varchar',
        'length' => 19,
        'not null' => TRUE,
        'description' => 'Last updated timestamp (YYYY-MM-DD HH:MM:SS)',
      ],
      'last_verified' => [
        'type' => 'varchar',
        'length' => 19,
        'description' => 'Last successful verification timestamp (YYYY-MM-DD HH:MM:SS)',
      ],
      'verification_status' => [
        'type' => 'varchar',
        'length' => 32,
        'default' => 'unverified',
        'description' => 'unverified, verified, failed, expired',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'user_company_type' => ['uid', 'company_id', 'credential_type'],
    ],
    'indexes' => [
      'uid' => ['uid'],
      'company_id' => ['company_id'],
      'credential_type' => ['credential_type'],
      'verification_status' => ['verification_status'],
      'uid_company' => ['uid', 'company_id'],
      'created' => ['created'],
    ],
    'foreign keys' => [
      'uid_fk' => [
        'table' => 'users',
        'columns' => ['uid' => 'uid'],
      ],
      'company_id_fk' => [
        'table' => 'jobhunter_companies',
        'columns' => ['company_id' => 'id'],
      ],
    ],
  ];

  $schema->createTable('jobhunter_employer_credentials', $table_schema);
}

/**
 * Create employer credentials table on update.
 */
function job_hunter_update_9028() {
  _job_hunter_create_employer_credentials_table();
  return t('Created jobhunter_employer_credentials table for securely storing encrypted employer credentials.');
}

/**
 * Add projection columns to jobhunter_job_seeker for query-friendly access.
 *
 * These fields are derived from consolidated_profile_json and are intended
 * for filtering/sorting without JSON parsing.
 */
function job_hunter_update_9029() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('jobhunter_job_seeker')) {
    return t('Table jobhunter_job_seeker does not exist.');
  }

  $fields = [
    'full_name' => [
      'type' => 'varchar',
      'length' => 255,
      'description' => 'Projected full name from consolidated profile JSON.',
    ],
    'contact_email' => [
      'type' => 'varchar',
      'length' => 255,
      'description' => 'Projected email from consolidated profile JSON.',
    ],
    'contact_phone' => [
      'type' => 'varchar',
      'length' => 64,
      'description' => 'Projected phone from consolidated profile JSON.',
    ],
    'location_city' => [
      'type' => 'varchar',
      'length' => 128,
      'description' => 'Projected city from consolidated profile JSON.',
    ],
    'location_state' => [
      'type' => 'varchar',
      'length' => 64,
      'description' => 'Projected state/region from consolidated profile JSON.',
    ],
    'remote_preference' => [
      'type' => 'varchar',
      'length' => 32,
      'description' => 'Projected remote preference (remote|hybrid|onsite|any).',
    ],
    'relocation_willing' => [
      'type' => 'int',
      'size' => 'tiny',
      'default' => 0,
      'description' => 'Projected relocation willingness (1=yes,0=no).',
    ],
    'salary_min' => [
      'type' => 'int',
      'not null' => FALSE,
      'description' => 'Projected minimum salary expectation.',
    ],
    'salary_max' => [
      'type' => 'int',
      'not null' => FALSE,
      'description' => 'Projected maximum salary expectation.',
    ],
    'available_start_date' => [
      'type' => 'varchar',
      'length' => 10,
      'description' => 'Projected available start date (YYYY-MM-DD).',
    ],
    'linkedin_url' => [
      'type' => 'varchar',
      'length' => 512,
      'description' => 'Projected LinkedIn URL from consolidated profile JSON.',
    ],
    'github_url' => [
      'type' => 'varchar',
      'length' => 512,
      'description' => 'Projected GitHub URL from consolidated profile JSON.',
    ],
    'portfolio_url' => [
      'type' => 'varchar',
      'length' => 512,
      'description' => 'Projected portfolio/personal site URL from consolidated profile JSON.',
    ],
    'projection_updated' => [
      'type' => 'int',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Timestamp when projection columns were last updated.',
    ],
  ];

  $added = [];
  foreach ($fields as $name => $spec) {
    if (!$schema->fieldExists('jobhunter_job_seeker', $name)) {
      $schema->addField('jobhunter_job_seeker', $name, $spec);
      $added[] = $name;
    }
  }

  // Add a few lightweight indexes for common filters.
  if (!$schema->indexExists('jobhunter_job_seeker', 'idx_location_state')) {
    $schema->addIndex('jobhunter_job_seeker', 'idx_location_state', ['location_state'], [
      'fields' => [
        'location_state' => ['type' => 'varchar', 'length' => 64],
      ],
    ]);
  }
  if (!$schema->indexExists('jobhunter_job_seeker', 'idx_remote_preference')) {
    $schema->addIndex('jobhunter_job_seeker', 'idx_remote_preference', ['remote_preference'], [
      'fields' => [
        'remote_preference' => ['type' => 'varchar', 'length' => 32],
      ],
    ]);
  }
  if (!$schema->indexExists('jobhunter_job_seeker', 'idx_salary_min')) {
    $schema->addIndex('jobhunter_job_seeker', 'idx_salary_min', ['salary_min'], [
      'fields' => [
        'salary_min' => ['type' => 'int'],
      ],
    ]);
  }

  if (empty($added)) {
    return t('No update needed - projection columns already exist.');
  }

  return t('Added projection columns to jobhunter_job_seeker: @columns', [
    '@columns' => implode(', ', $added),
  ]);
}

/**
 * Ensure projection indexes exist for jobhunter_job_seeker.
 *
 * This is separate from 9029 because 9029 may have partially applied before
 * failing (e.g., columns created but indexes missing).
 */
function job_hunter_update_9030() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('jobhunter_job_seeker')) {
    return t('Table jobhunter_job_seeker does not exist.');
  }

  $created = [];

  if (!$schema->indexExists('jobhunter_job_seeker', 'idx_location_state') && $schema->fieldExists('jobhunter_job_seeker', 'location_state')) {
    $schema->addIndex('jobhunter_job_seeker', 'idx_location_state', ['location_state'], [
      'fields' => [
        'location_state' => ['type' => 'varchar', 'length' => 64],
      ],
    ]);
    $created[] = 'idx_location_state';
  }

  if (!$schema->indexExists('jobhunter_job_seeker', 'idx_remote_preference') && $schema->fieldExists('jobhunter_job_seeker', 'remote_preference')) {
    $schema->addIndex('jobhunter_job_seeker', 'idx_remote_preference', ['remote_preference'], [
      'fields' => [
        'remote_preference' => ['type' => 'varchar', 'length' => 32],
      ],
    ]);
    $created[] = 'idx_remote_preference';
  }

  if (!$schema->indexExists('jobhunter_job_seeker', 'idx_salary_min') && $schema->fieldExists('jobhunter_job_seeker', 'salary_min')) {
    $schema->addIndex('jobhunter_job_seeker', 'idx_salary_min', ['salary_min'], [
      'fields' => [
        'salary_min' => ['type' => 'int'],
      ],
    ]);
    $created[] = 'idx_salary_min';
  }

  if (empty($created)) {
    return t('No update needed - projection indexes already exist.');
  }

  return t('Created projection indexes: @indexes', [
    '@indexes' => implode(', ', $created),
  ]);
}

/**
 * Backfill projection columns after table recreation/schema drift.
 */
function job_hunter_update_9031() {
  $result = job_hunter_update_9029();
  job_hunter_update_9030();
  return $result;
}

/**
 * Add application automation tracking columns and attempts table.
 */
function job_hunter_update_9032() {
  $schema = \Drupal::database()->schema();
  $added = [];

  // Add new columns to jobhunter_applications.
  $new_columns = [
    'ats_platform' => [
      'type' => 'varchar',
      'length' => 50,
      'not null' => FALSE,
      'description' => 'Detected ATS platform: workday, greenhouse, lever, taleo, icims, usajobs, custom, aggregator',
    ],
    'apply_url' => [
      'type' => 'varchar',
      'length' => 1000,
      'not null' => FALSE,
      'description' => 'Resolved canonical apply URL after following aggregator redirects',
    ],
    'selected_apply_option' => [
      'type' => 'varchar',
      'length' => 100,
      'not null' => FALSE,
      'description' => 'Title of the apply_option selected from job apply_options array',
    ],
    'attempt_count' => [
      'type' => 'int',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Number of submission attempts made',
    ],
    'metadata' => [
      'type' => 'text',
      'not null' => FALSE,
      'description' => 'JSON metadata: form field mapping, resolution steps, ATS detection details',
    ],
  ];

  foreach ($new_columns as $column_name => $spec) {
    if (!$schema->fieldExists('jobhunter_applications', $column_name)) {
      $schema->addField('jobhunter_applications', $column_name, $spec);
      $added[] = "applications.$column_name";
    }
  }

  // Create jobhunter_application_attempts table.
  if (!$schema->tableExists('jobhunter_application_attempts')) {
    $schema->createTable('jobhunter_application_attempts', [
      'description' => 'Log of each automated application submission attempt.',
      'fields' => [
        'id' => ['type' => 'serial', 'not null' => TRUE],
        'application_id' => ['type' => 'int', 'not null' => TRUE, 'description' => 'FK to jobhunter_applications.id'],
        'uid' => ['type' => 'int', 'not null' => TRUE],
        'attempted_at' => ['type' => 'varchar', 'length' => 19, 'description' => 'YYYY-MM-DD HH:MM:SS'],
        'url_tried' => ['type' => 'varchar', 'length' => 1000, 'description' => 'URL attempted'],
        'ats_detected' => ['type' => 'varchar', 'length' => 50, 'description' => 'ATS platform detected at attempt time'],
        'outcome' => [
          'type' => 'varchar',
          'length' => 50,
          'description' => 'success, failed, manual_required, blocked, timeout, unsupported',
        ],
        'duration_ms' => ['type' => 'int', 'default' => 0, 'description' => 'Attempt duration in milliseconds'],
        'error_message' => ['type' => 'text', 'description' => 'Error message if failed'],
        'metadata' => ['type' => 'text', 'description' => 'JSON: HTTP status, redirect chain, form fields found'],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'application_id' => ['application_id'],
        'uid' => ['uid'],
        'outcome' => ['outcome'],
        'attempted_at' => ['attempted_at'],
      ],
    ]);
    $added[] = 'table:jobhunter_application_attempts';
  }

  return empty($added)
    ? t('No schema changes needed.')
    : t('Application automation schema updated: @items', ['@items' => implode(', ', $added)]);
}

/**
 * Implements hook_update_N().
 *
 * Phase 2: Add screenshot evidence columns to jobhunter_application_attempts
 * and confirmation tracking to jobhunter_applications.
 */
function job_hunter_update_9033() {
  $schema = \Drupal::database()->schema();
  $added = [];

  // Add Phase 2 evidence columns to jobhunter_application_attempts.
  $attempt_columns = [
    'screenshot_pre_path' => [
      'type' => 'varchar',
      'length' => 500,
      'not null' => FALSE,
      'description' => 'Private fs path to pre-submit form screenshot',
    ],
    'screenshot_post_path' => [
      'type' => 'varchar',
      'length' => 500,
      'not null' => FALSE,
      'description' => 'Private fs path to post-submit confirmation screenshot',
    ],
    'confirmation_text' => [
      'type' => 'text',
      'not null' => FALSE,
      'description' => 'Full confirmation text extracted from the page after submission',
    ],
    'confirmation_number' => [
      'type' => 'varchar',
      'length' => 100,
      'not null' => FALSE,
      'description' => 'Parsed confirmation/reference number (e.g. APP-2026-884321)',
    ],
  ];

  foreach ($attempt_columns as $col => $spec) {
    if (!$schema->fieldExists('jobhunter_application_attempts', $col)) {
      $schema->addField('jobhunter_application_attempts', $col, $spec);
      $added[] = "attempts.$col";
    }
  }

  // Add confirmation tracking columns to jobhunter_applications.
  $application_columns = [
    'confirmed_at' => [
      'type' => 'varchar',
      'length' => 19,
      'not null' => FALSE,
      'description' => 'Datetime when submission confirmation was captured (YYYY-MM-DD HH:MM:SS)',
    ],
    'confirmation_ref' => [
      'type' => 'varchar',
      'length' => 100,
      'not null' => FALSE,
      'description' => 'Employer confirmation reference number',
    ],
  ];

  foreach ($application_columns as $col => $spec) {
    if (!$schema->fieldExists('jobhunter_applications', $col)) {
      $schema->addField('jobhunter_applications', $col, $spec);
      $added[] = "applications.$col";
    }
  }

  return empty($added)
    ? t('No Phase 2 schema changes needed.')
    : t('Phase 2 evidence schema added: @items', ['@items' => implode(', ', $added)]);
}

/**
 * Ensure ats_platform exists on jobhunter_applications.
 *
 * Recovery hook for environments that missed or partially applied 9032.
 */
function job_hunter_update_9034() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('jobhunter_applications')) {
    return t('No update needed: table jobhunter_applications does not exist.');
  }

  if ($schema->fieldExists('jobhunter_applications', 'ats_platform')) {
    return t('No update needed: applications.ats_platform already exists.');
  }

  $schema->addField('jobhunter_applications', 'ats_platform', [
    'type' => 'varchar',
    'length' => 50,
    'not null' => FALSE,
    'description' => 'Detected ATS platform: workday, greenhouse, lever, taleo, icims, usajobs, custom, aggregator',
  ]);

  return t('Added missing applications.ats_platform column.');
}

/**
 * Ensure job_hash exists for imported-job deduplication queries.
 *
 * Recovery hook for environments that missed historical update 9023.
 */
function job_hunter_update_9035() {
  $schema = \Drupal::database()->schema();
  $added = [];

  if (!$schema->tableExists('jobhunter_job_requirements')) {
    return t('No update needed: table jobhunter_job_requirements does not exist.');
  }

  if (!$schema->fieldExists('jobhunter_job_requirements', 'job_hash')) {
    $schema->addField('jobhunter_job_requirements', 'job_hash', [
      'type' => 'varchar',
      'length' => 32,
      'not null' => FALSE,
      'description' => 'MD5 hash of normalized company|title|location for cross-source deduplication.',
    ]);
    $added[] = 'job_hash';
  }

  if ($schema->fieldExists('jobhunter_job_requirements', 'job_hash') && !$schema->indexExists('jobhunter_job_requirements', 'idx_job_hash')) {
    $schema->addIndex('jobhunter_job_requirements', 'idx_job_hash', ['job_hash'], [
      'fields' => [
        'job_hash' => [
          'type' => 'varchar',
          'length' => 32,
        ],
      ],
    ]);
    $added[] = 'idx_job_hash';
  }

  return empty($added)
    ? t('No update needed: job_hash schema already present.')
    : t('Added missing job hash schema: @items', ['@items' => implode(', ', $added)]);
}

