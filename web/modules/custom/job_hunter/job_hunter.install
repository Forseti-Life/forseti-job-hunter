  $schema = \Drupal::database()->schema();
  if ($schema->tableExists('jobhunter_contact_job_links')) {
    return t('jobhunter_contact_job_links already exists.');
  }
  $schema->createTable('jobhunter_contact_job_links', [
    'description' => 'Links between user contacts and saved jobs for referral tracking.',
    'fields' => [
      'id'           => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
      'uid'          => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      'contact_id'   => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE],
      'saved_job_id' => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE],
      'created'      => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
    ],
    'primary key' => ['id'],
    'unique keys' => ['uid_contact_job' => ['uid', 'contact_id', 'saved_job_id']],
    'indexes' => [
      'uid'          => ['uid'],
      'saved_job_id' => ['saved_job_id'],
    ],
  ]);
  return t('Created jobhunter_contact_job_links table for referral tracking.');
}

/**
 * Add submitted_resume_id and submitted_resume_type to jobhunter_applications.
 *
 * Migrates existing source_resume_id data (base resumes) into the new columns.
 */
function job_hunter_update_9057() {
  $schema = \Drupal::database()->schema();
  $db = \Drupal::database();

  if (!$schema->fieldExists('jobhunter_applications', 'submitted_resume_id')) {
    $schema->addField('jobhunter_applications', 'submitted_resume_id', [
      'type' => 'int',
      'unsigned' => TRUE,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'FK to base or tailored resume used for this application.',
    ]);
  }

  if (!$schema->fieldExists('jobhunter_applications', 'submitted_resume_type')) {
    $schema->addField('jobhunter_applications', 'submitted_resume_type', [
      'type' => 'varchar',
      'length' => 16,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Resume type: base or tailored.',
    ]);
  }

  // Migrate existing source_resume_id values to the new columns.
  $db->query("UPDATE {jobhunter_applications} SET submitted_resume_id = source_resume_id, submitted_resume_type = 'base' WHERE source_resume_id IS NOT NULL AND submitted_resume_id IS NULL");

  return t('Added submitted_resume_id and submitted_resume_type to jobhunter_applications; migrated existing source_resume_id data.');
}

/**
 * Create jobhunter_offers table for offer tracking.
 */
function _job_hunter_create_offers_table(): void {
  $schema = \Drupal::database()->schema();
  if ($schema->tableExists('jobhunter_offers')) {
    return;
  }
  $schema->createTable('jobhunter_offers', [
    'description' => 'Offer details per user per saved job.',
    'fields' => [
      'id'               => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
      'uid'              => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      'saved_job_id'     => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE],
      'base_salary'      => ['type' => 'int', 'size' => 'normal', 'not null' => FALSE, 'default' => NULL],
      'equity_summary'   => ['type' => 'text', 'size' => 'medium', 'not null' => FALSE],
      'benefits_summary' => ['type' => 'text', 'size' => 'medium', 'not null' => FALSE],
      'response_deadline' => ['type' => 'varchar', 'length' => 10, 'not null' => FALSE, 'default' => NULL],
      'notes'            => ['type' => 'text', 'size' => 'medium', 'not null' => FALSE],
      'created'          => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
      'changed'          => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
    ],
    'primary key' => ['id'],
    'unique keys' => ['uid_saved_job' => ['uid', 'saved_job_id']],
    'indexes' => [
      'uid' => ['uid'],
    ],
  ]);
}

/**
 * Create jobhunter_offers table for offer tracking.
 */
function job_hunter_update_9058() {
  _job_hunter_create_offers_table();
  return t('Created jobhunter_offers table for offer tracking.');
}

/**
 * Realign jobhunter_contacts with the company_id-backed contact tracker brief.
 */
function job_hunter_update_9059() {
  $schema = \Drupal::database()->schema();
  $db = \Drupal::database();

  if (!$schema->tableExists('jobhunter_contacts')) {
    return t('jobhunter_contacts does not exist.');
  }

  if (!$schema->fieldExists('jobhunter_contacts', 'name')) {
    $schema->addField('jobhunter_contacts', 'name', [
      'type' => 'varchar',
      'length' => 255,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Display name for the contact.',
    ]);
  }

  if (!$schema->fieldExists('jobhunter_contacts', 'title')) {
    $schema->addField('jobhunter_contacts', 'title', [
      'type' => 'varchar',
      'length' => 255,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Role or title for the contact.',
    ]);
  }

  if (!$schema->fieldExists('jobhunter_contacts', 'company_id')) {
    $schema->addField('jobhunter_contacts', 'company_id', [
      'type' => 'int',
      'unsigned' => TRUE,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Referenced company from jobhunter_companies.',
    ]);
  }

  if ($schema->fieldExists('jobhunter_contacts', 'full_name')) {
    $db->query("
      UPDATE {jobhunter_contacts}
      SET name = full_name
      WHERE (name IS NULL OR name = '')
        AND full_name IS NOT NULL
        AND full_name <> ''
    ");
  }

  if ($schema->fieldExists('jobhunter_contacts', 'job_title')) {
    $db->query("
      UPDATE {jobhunter_contacts}
      SET title = job_title
      WHERE (title IS NULL OR title = '')
        AND job_title IS NOT NULL
        AND job_title <> ''
    ");
  }

  if ($schema->fieldExists('jobhunter_contacts', 'company_name')) {
    $legacy_contacts = $db->select('jobhunter_contacts', 'ct')
      ->fields('ct', ['id', 'company_name'])
      ->isNull('company_id')
      ->condition('company_name', '', '<>')
      ->execute()
      ->fetchAllAssoc('id');

    foreach ($legacy_contacts as $contact_id => $contact) {
      $company_name = trim((string) $contact->company_name);
      if ($company_name === '') {
        continue;
      }

      $matched_company_id = $db->select('jobhunter_companies', 'c')
        ->fields('c', ['id'])
        ->condition('name', $company_name)
        ->range(0, 1)
        ->execute()
        ->fetchField();

      if ($matched_company_id !== FALSE) {
        $db->update('jobhunter_contacts')
          ->fields(['company_id' => (int) $matched_company_id])
          ->condition('id', (int) $contact_id)
          ->execute();
      }
    }
  }

  $db->query("
    UPDATE {jobhunter_contacts}
    SET relationship_type = CASE relationship_type
      WHEN 'colleague' THEN 'connection'
      WHEN 'friend' THEN 'connection'
      WHEN 'alumni' THEN 'connection'
      WHEN 'other' THEN 'cold'
      ELSE relationship_type
    END
  ");

  $db->query("
    UPDATE {jobhunter_contacts}
    SET referral_status = CASE referral_status
      WHEN 'referred' THEN 'provided'
      WHEN 'pending-referral' THEN 'pending'
      ELSE referral_status
    END
  ");

  $db->query("
    UPDATE {jobhunter_contacts}
    SET referral_status = 'none'
    WHERE referral_status NOT IN ('none', 'requested', 'pending', 'provided')
  ");

  return t('Realigned jobhunter_contacts with company_id-backed contact tracking.');
}

/**
 * Add email and linkedin_url columns to jobhunter_contacts (AC-4 / SEC-4).
 */
function job_hunter_update_9060() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('jobhunter_contacts')) {
    return t('jobhunter_contacts does not exist — skipped.');
  }

  if (!$schema->fieldExists('jobhunter_contacts', 'email')) {
    $schema->addField('jobhunter_contacts', 'email', [
      'type' => 'varchar',
      'length' => 255,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Contact email address (optional).',
    ]);
  }

  if (!$schema->fieldExists('jobhunter_contacts', 'linkedin_url')) {
    $schema->addField('jobhunter_contacts', 'linkedin_url', [
      'type' => 'varchar',
      'length' => 512,
      'not null' => FALSE,
      'default' => NULL,
      'description' => 'Contact LinkedIn profile URL (optional).',
    ]);
  }

  return t('Added email and linkedin_url columns to jobhunter_contacts.');
}

/**
 * Create job_hunter_profile table with age_18_or_older field.
 *
 * Resolves schema mismatch where UserProfileForm declares db_column: 'age_18_or_older'
 * but the table did not exist. This update creates the job_hunter_profile table
 * to support the field definition used by the form.
 */
function job_hunter_update_9061() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('job_hunter_profile')) {
    return t('job_hunter_profile table already exists — skipped.');
  }

  $table_schema = [
    'description' => 'Job hunter profile data.',
    'fields' => [
      'uid' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'User ID (primary key).',
      ],
      'age_18_or_older' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => FALSE,
        'default' => NULL,
        'description' => 'Whether applicant is 18 or older (1=yes, 0=no, NULL=unknown).',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Timestamp when row was created.',
      ],
      'changed' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Timestamp when row was last modified.',
      ],
    ],
    'primary key' => ['uid'],
  ];

  $schema->createTable('job_hunter_profile', $table_schema);

  return t('Created job_hunter_profile table with age_18_or_older field.');
}
