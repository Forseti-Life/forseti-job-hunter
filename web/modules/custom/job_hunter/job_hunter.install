  }
  
  $table_schema = [
    'description' => 'Tracks search queries sent to Google Cloud Talent Solution API',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
        'description' => 'Primary key',
      ],
      'uid' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'User ID who performed the search',
      ],
      'query_text' => [
        'type' => 'varchar',
        'length' => 512,
        'description' => 'Search query text',
      ],
      'location' => [
        'type' => 'varchar',
        'length' => 255,
        'description' => 'Location filter',
      ],
      'search_params_json' => [
        'type' => 'text',
        'size' => 'medium',
        'description' => 'Complete JSON of all search parameters sent to API',
      ],
      'company_name' => [
        'type' => 'varchar',
        'length' => 255,
        'description' => 'Company name filter',
      ],
      'employment_types' => [
        'type' => 'varchar',
        'length' => 255,
        'description' => 'Comma-separated employment types (FULL_TIME, PART_TIME, etc.)',
      ],
      'job_categories' => [
        'type' => 'text',
        'description' => 'Comma-separated job categories',
      ],
      'page_token' => [
        'type' => 'varchar',
        'length' => 512,
        'description' => 'Pagination token used for this query',
      ],
      'page_size' => [
        'type' => 'int',
        'default' => 10,
        'description' => 'Number of results requested',
      ],
      'total_results' => [
        'type' => 'int',
        'default' => 0,
        'description' => 'Total number of results returned by API',
      ],
      'next_page_token' => [
        'type' => 'varchar',
        'length' => 512,
        'description' => 'Next page token returned by API',
      ],
      'api_response_time_ms' => [
        'type' => 'int',
        'description' => 'API response time in milliseconds',
      ],
      'status' => [
        'type' => 'varchar',
        'length' => 50,
        'default' => 'completed',
        'description' => 'Status: completed, error, timeout',
      ],
      'error_message' => [
        'type' => 'text',
        'description' => 'Error message if status is error',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Timestamp when search was performed',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'uid' => ['uid'],
      'status' => ['status'],
      'created' => ['created'],
      'query_text' => [['query_text', 100]],
      'location' => [['location', 100]],
      'company_name' => [['company_name', 100]],
    ],
  ];
  
  $schema->createTable('jobhunter_job_search_queries', $table_schema);
}

/**
