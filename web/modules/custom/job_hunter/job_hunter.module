<?php

/**
 * @file
 * Contains job_hunter.module.
 * 
 * This module provides job application automation functionality including
 * job tracking, application workflow management, and external service integration.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function job_hunter_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.job_hunter':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('The Job Application Automation module provides comprehensive tools for managing job applications, tracking application status, and automating workflow processes.') . '</p>';
      $output .= '<h3>' . t('Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Job application tracking and management') . '</li>';
      $output .= '<li>' . t('Automated workflow processes') . '</li>';
      $output .= '<li>' . t('Integration with external job boards and services') . '</li>';
      $output .= '<li>' . t('Customizable application templates') . '</li>';
      $output .= '<li>' . t('Status tracking and notifications') . '</li>';
      $output .= '</ul>';
      return $output;

    default:
  }
}

