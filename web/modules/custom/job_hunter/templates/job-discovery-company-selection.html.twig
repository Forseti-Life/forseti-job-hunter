{#
/**
 * @file
 * Template for job discovery company selection page.
 *
 * Available variables:
 * - user: The user entity
 * - profile: The job seeker profile
 * - companies: Array of company entities
 * - keywords: Array of keywords from user profile
 */
#}

<div class="job-discovery-company-selection">
  <div class="container">
    {# Page Header #}
    <div class="job-discovery-header">
      <h1>{{ 'AI Job Discovery'|t }}</h1>
      <p class="discovery-subtitle">
        {{ 'Select a company to discover job opportunities tailored to your profile'|t }}
      </p>
    </div>

    <div class="discovery-content">
      {# Profile Summary #}
      <div class="discovery-card profile-summary">
        <h2>{{ 'Your Profile Keywords'|t }}</h2>
        <div class="keywords-preview">
          {% if keywords %}
            <div class="keywords-list">
              {% for keyword in keywords %}
                <span class="keyword-tag">{{ keyword }}</span>
              {% endfor %}
            </div>
            <p class="keywords-note">
              {{ 'We\'ll use these keywords to find relevant opportunities at your selected company.'|t }}
            </p>
          {% else %}
            <p class="no-keywords">
              {{ 'No keywords found in your profile. Consider updating your profile with relevant skills and interests.'|t }}
            </p>
          {% endif %}
        </div>
      </div>

      {# Company Selection #}
      <div class="discovery-card companies-section">
        <h2>{{ 'Select a Company'|t }}</h2>
        <p class="section-description">
          {{ 'Choose a company to search for job opportunities. Our AI will scrape their careers page and find positions matching your profile.'|t }}
        </p>
        
                <div class="companies-list">
          {% for company in companies %}
            <div class="company-item">
              <h3>{{ company.getTitle() }}</h3>
              <a href="{{ path('job_hunter.company_job_discovery', {'user': user.id(), 'company': company.id()}) }}" 
                 class="btn btn-primary">
                {{ 'Discover Jobs'|t }}
              </a>
            </div>
          {% endfor %}
        </div>
      </div>

      {# Help Section #}
      <div class="discovery-card help-section">
        <h2>{{ 'How It Works'|t }}</h2>
        <div class="help-steps">
          <div class="help-step">
            <div class="step-number">1</div>
            <div class="step-content">
              <h4>{{ 'Select Company'|t }}</h4>
              <p>{{ 'Choose a company from the list above'|t }}</p>
            </div>
          </div>
          <div class="help-step">
            <div class="step-number">2</div>
            <div class="step-content">
              <h4>{{ 'AI Search'|t }}</h4>
              <p>{{ 'Our AI scrapes their careers page using your profile keywords'|t }}</p>
            </div>
          </div>
          <div class="help-step">
            <div class="step-number">3</div>
            <div class="step-content">
              <h4>{{ 'Review & Save'|t }}</h4>
              <p>{{ 'Review matched positions and save interesting ones to your dashboard'|t }}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>