{#
/**
 * @file
 * Template: Saved Searches list page.
 *
 * Variables:
 * - saved_searches: Array of saved search objects (id, keywords, location, created).
 * - saved_searches_count: Integer count of saved searches.
 * - max_saved_searches: Maximum allowed (10).
 */
#}
<div class="saved-searches-page">
  <h1>{{ 'Saved Searches'|t }}</h1>
  <p class="text-muted">
    {{ saved_searches_count }} {{ 'of'|t }} {{ max_saved_searches }} {{ 'saved searches used.'|t }}
  </p>

  {% if saved_searches is not empty %}
    <ul class="list-group">
      {% for saved in saved_searches %}
        {% set rerun_url = '/jobhunter/googlejobssearch?q=' ~ saved.keywords|url_encode ~ (saved.location ? '&location=' ~ saved.location|url_encode : '') %}
        {% set delete_url = path('job_hunter.saved_search_delete', {'saved_search_id': saved.id}) %}
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <span>
            <strong>{{ saved.keywords|e }}</strong>
            {% if saved.location %}
              <span class="text-muted"> &mdash; {{ saved.location|e }}</span>
            {% endif %}
          </span>
          <span>
            <a href="{{ rerun_url }}" class="btn btn-sm btn-outline-primary me-1">
              <i class="bi bi-play"></i> {{ 'Re-run'|t }}
            </a>
            <form method="post" action="{{ delete_url }}" style="display:inline-block;">
              <button type="submit" class="btn btn-sm btn-outline-danger"
                      onclick="return confirm('{{ 'Delete this saved search?'|t }}')">
                <i class="bi bi-trash"></i> {{ 'Delete'|t }}
              </button>
            </form>
          </span>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <div class="text-center py-5 text-muted">
      <i class="bi bi-bookmark display-4"></i>
      <p class="mt-3">{{ 'No saved searches yet. Run a search and click "Save this search".'|t }}</p>
      <a href="/jobhunter/googlejobssearch" class="btn btn-primary">{{ 'Search Jobs'|t }}</a>
    </div>
  {% endif %}

  <p class="mt-3">
    <a href="/jobhunter/googlejobssearch">&larr; {{ 'Back to Job Search'|t }}</a>
  </p>
</div>
