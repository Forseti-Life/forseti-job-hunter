{#
  Template: credentials-management.html.twig
  Variables:
    credentials  - array of stored credentials (metadata only, never plaintext)
    companies    - array of id => name for the add form dropdown
    ats_platforms - array of platform_key => label
    add_form     - rendered CredentialForm
#}

<div class="credentials-management-page">
  <div class="page-header">
    <h1>🔑 {{ 'ATS Credentials'|t }}</h1>
    <p class="page-description">
      {{ 'Store your login credentials for employer ATS portals (Workday, iCIMS, Taleo, etc.). Required for Phase 2 automated application submission on login-gated platforms.'|t }}
    </p>
  </div>

  {# ── Status Banner ── #}
  <div class="messages messages--info credential-info-banner">
    <strong>{{ 'How it works:'|t }}</strong>
    <ol>
      <li>{{ 'Store your login for an employer portal below.'|t }}</li>
      <li>{{ 'When you click Apply on a job that uses that portal, the system logs in and fills the form automatically.'|t }}</li>
      <li>{{ 'Credentials are encrypted with AES-256-CBC and never displayed in plaintext.'|t }}</li>
    </ol>
  </div>

  {# ── Stored Credentials Table ── #}
  <section class="stored-credentials">
    <h2>{{ 'Stored Credentials'|t }}</h2>

    {% if credentials is empty %}
      <div class="empty-state">
        <p>{{ 'No credentials stored yet. Add your first one below.'|t }}</p>
      </div>
    {% else %}
      <table class="credential-table responsive-enabled">
        <thead>
          <tr>
            <th>{{ 'Employer'|t }}</th>
            <th>{{ 'ATS Platform'|t }}</th>
            <th>{{ 'Portal URL'|t }}</th>
            <th>{{ 'Status'|t }}</th>
            <th>{{ 'Stored'|t }}</th>
            <th>{{ 'Actions'|t }}</th>
          </tr>
        </thead>
        <tbody>
          {% for id, cred in credentials %}
            <tr class="credential-row" data-credential-id="{{ id }}">
              <td class="company-name">{{ cred.company_name }}</td>
              <td class="platform-label">{{ cred.platform_label }}</td>
              <td class="submission-url">
                {% if cred.submission_url %}
                  <a href="{{ cred.submission_url }}" target="_blank" rel="noopener">
                    {{ cred.submission_url|length > 50 ? cred.submission_url[:47] ~ '...' : cred.submission_url }}
                  </a>
                {% else %}
                  <span class="text-muted">—</span>
                {% endif %}
              </td>
              <td class="status-cell">
                <span class="credential-status status--{{ cred.verification_status|default('unverified') }}">
                  {{ cred.status_badge }}
                </span>
              </td>
              <td class="created-date">{{ cred.created|date('M j, Y') }}</td>
              <td class="actions-cell">
                <button class="button button--small btn-test-credential"
                        data-credential-id="{{ id }}"
                        data-test-url="{{ path('job_hunter.credentials_test', {credential_id: id}) }}"
                        title="{{ 'Queue a credential verification test'|t }}">
                  🔍 {{ 'Test'|t }}
                </button>
                <button class="button button--small button--danger btn-delete-credential"
                        data-credential-id="{{ id }}"
                        data-delete-url="{{ path('job_hunter.credentials_delete', {credential_id: id}) }}"
                        title="{{ 'Permanently delete this credential'|t }}"
                        onclick="return confirm('{{ 'Delete this credential? This cannot be undone.'|t }}')">
                  🗑 {{ 'Delete'|t }}
                </button>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </section>

  {# ── Add Credentials Form ── #}
  <section class="add-credential-section">
    <h2>{{ 'Add Credentials'|t }}</h2>
    {{ add_form }}
  </section>

  {# ── Supported Platforms Reference ── #}
  <section class="supported-platforms">
    <h2>{{ 'Supported Platforms'|t }}</h2>
    <p>{{ 'Credentials are used for automation on these login-required ATS platforms:'|t }}</p>
    <ul class="platform-list">
      {% for key, label in ats_platforms %}
        <li>
          <strong>{{ label }}</strong>
          <span class="platform-key text-muted">({{ key }})</span>
        </li>
      {% endfor %}
    </ul>
    <p class="platform-note">
      {{ 'Platforms like Greenhouse, Lever, Ashby, SmartRecruiters, and Workable do <strong>not</strong> require credentials — they use public apply forms.'|t|raw }}
    </p>
  </section>
</div>

{# ── JS for AJAX delete and test actions ── #}
<script>
(function () {
  document.addEventListener('DOMContentLoaded', function () {

    // Delete credential
    document.querySelectorAll('.btn-delete-credential').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        if (!confirm('Delete this credential? This cannot be undone.')) return;
        var credId   = btn.dataset.credentialId;
        var url      = btn.dataset.deleteUrl;
        var csrfUrl  = '/session/token';

        fetch(csrfUrl)
          .then(r => r.text())
          .then(function (token) {
            return fetch(url, {
              method: 'POST',
              headers: { 'X-CSRF-Token': token, 'Content-Type': 'application/json' },
              body: JSON.stringify({ credential_id: credId }),
            });
          })
          .then(r => r.json())
          .then(function (data) {
            if (data.success) {
              var row = document.querySelector('.credential-row[data-credential-id="' + credId + '"]');
              if (row) row.remove();
            } else {
              alert('Delete failed: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(function (err) { alert('Request failed: ' + err); });
      });
    });

    // Test credential
    document.querySelectorAll('.btn-test-credential').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        var credId  = btn.dataset.credentialId;
        var url     = btn.dataset.testUrl;
        var csrfUrl = '/session/token';

        btn.disabled = true;
        btn.textContent = '⏳ Queuing...';

        fetch(csrfUrl)
          .then(r => r.text())
          .then(function (token) {
            return fetch(url, {
              method: 'POST',
              headers: { 'X-CSRF-Token': token, 'Content-Type': 'application/json' },
            });
          })
          .then(r => r.json())
          .then(function (data) {
            btn.disabled = false;
            btn.textContent = '🔍 Test';
            if (data.success) {
              alert('✅ Credential test queued. Check back in a moment to see verification status.');
            } else {
              alert('Test failed: ' + (data.message || 'Unknown error'));
            }
          })
          .catch(function (err) {
            btn.disabled = false;
            btn.textContent = '🔍 Test';
            alert('Request failed: ' + err);
          });
      });
    });

  });
})();
</script>
