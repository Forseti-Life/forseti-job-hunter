{#
/**
 * @file
 * Template: Interview Prep Page.
 *
 * Variables:
 * - job: The job requirement object (id, job_title).
 * - job_id: Integer job ID.
 * - notes_text: Pre-existing notes text (may be empty).
 * - save_url: URL for POST /jobhunter/interview-prep/{job_id}/save.
 * - ai_tips_url: URL for POST /jobhunter/interview-prep/{job_id}/ai-tips.
 */
#}
<div class="interview-prep-page">
  <h1 class="interview-prep__title">
    {{ 'Interview Prep'|t }}{% if job.job_title %}: <em>{{ job.job_title }}</em>{% endif %}
  </h1>

  {# AC-2: Static prep checklist (local-state only in this release) #}
  <section class="interview-prep__checklist">
    <h2>{{ 'Preparation Checklist'|t }}</h2>
    <ul class="checklist">
      <li><label><input type="checkbox"> {{ 'Research the company (mission, products, recent news)'|t }}</label></li>
      <li><label><input type="checkbox"> {{ 'Review the job description and required skills'|t }}</label></li>
      <li><label><input type="checkbox"> {{ 'Prepare 3–5 STAR stories (Situation, Task, Action, Result)'|t }}</label></li>
      <li><label><input type="checkbox"> {{ 'Prepare thoughtful questions to ask the interviewer'|t }}</label></li>
      <li><label><input type="checkbox"> {{ 'Confirm logistics (location, time zone, interview format, contact)'|t }}</label></li>
    </ul>
  </section>

  {# AC-5: AI tips section #}
  <section class="interview-prep__ai-tips">
    <h2>{{ 'AI Interview Tips'|t }}</h2>
    <button id="get-ai-tips-btn" class="button button--primary" type="button">
      {{ 'Get AI Interview Tips'|t }}
    </button>
    <div id="ai-tips-result" class="ai-tips-result" aria-live="polite" style="margin-top: 1em;"></div>
  </section>

  {# AC-3 / AC-4: Notes field #}
  <section class="interview-prep__notes">
    <h2>{{ 'My Notes'|t }}</h2>
    <form method="post" action="{{ save_url }}">
      <textarea
        name="notes_text"
        id="interview-notes"
        rows="10"
        cols="80"
        maxlength="10000"
        placeholder="{{ 'Add your notes here… (max 10,000 characters)'|t }}"
        class="interview-prep__notes-textarea"
      >{{ notes_text|e }}</textarea>
      <div class="form-actions">
        <button type="submit" class="button button--primary">{{ 'Save Notes'|t }}</button>
      </div>
    </form>
  </section>

  <p class="interview-prep__back">
    <a href="/jobhunter/my-jobs">&larr; {{ 'Back to My Jobs'|t }}</a>
  </p>
</div>

<script>
(function () {
  var btn = document.getElementById('get-ai-tips-btn');
  var resultEl = document.getElementById('ai-tips-result');
  if (!btn || !resultEl) { return; }

  btn.addEventListener('click', function () {
    btn.disabled = true;
    btn.textContent = 'Generating tips…';
    resultEl.innerHTML = '';

    var aiTipsUrl = {{ ai_tips_url|json_encode|raw }};

    fetch(aiTipsUrl, {
      method: 'POST',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
      },
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      if (data.error) {
        resultEl.innerHTML = '<p class="error-message">' + data.error + '</p>';
      } else if (Array.isArray(data.tips) && data.tips.length > 0) {
        var html = '<ul class="ai-tips-list">';
        data.tips.forEach(function (tip) {
          html += '<li>' + tip.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</li>';
        });
        html += '</ul>';
        resultEl.innerHTML = html;
      } else {
        resultEl.innerHTML = '<p>{{ 'No tips returned. Please try again.'|t }}</p>';
      }
    })
    .catch(function () {
      resultEl.innerHTML = '<p class="error-message">{{ 'An error occurred. Please try again.'|t }}</p>';
    })
    .finally(function () {
      btn.disabled = false;
      btn.textContent = '{{ 'Get AI Interview Tips'|t }}';
    });
  });
}());
</script>
