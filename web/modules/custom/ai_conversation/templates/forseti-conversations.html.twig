{#
/**
 * @file
 * Template for the Forseti conversation history list page at /forseti/conversations.
 *
 * Available variables:
 * - conversations: Array of conversation rows (id, title, preview, changed, message_count,
 *   total_tokens, chat_url, delete_url).
 * - total: Number of conversations on this page.
 * - page: Current page number (1-based).
 * - per_page: Items per page.
 * - has_next: Boolean — true if a next page exists.
 * - has_prev: Boolean — true if a previous page exists.
 */
#}

<div class="forseti-conversations">

  <div class="forseti-conversations__header d-flex justify-content-between align-items-center mb-4">
    <h1 class="forseti-conversations__title">{{ 'My Conversations'|t }}</h1>
    <a href="{{ path('ai_conversation.forseti_chat') }}" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> {{ 'New Conversation'|t }}
    </a>
  </div>

  {# AC-6: Empty state #}
  {% if conversations is empty %}
    <div class="forseti-conversations__empty text-center py-5 text-muted">
      <i class="bi bi-chat-left-dots display-4"></i>
      <h4 class="mt-3">{{ 'No conversations yet'|t }}</h4>
      <p>
        <a href="{{ path('ai_conversation.forseti_chat') }}" class="btn btn-success mt-2">
          {{ 'Start your first conversation'|t }}
        </a>
      </p>
    </div>
  {% else %}

    {# AC-2: Conversation list #}
    <div class="forseti-conversations__list">
      {% for conv in conversations %}
        {% set delete_url = path('forseti.conversation_delete', {'conversation_id': conv.id}) %}
        <div class="card forseti-conversations__item mb-3">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div class="forseti-conversations__meta">
                <h5 class="card-title mb-1">{{ conv.title|e }}</h5>
                <p class="text-muted small mb-1">
                  <i class="bi bi-clock"></i>
                  {{ conv.changed|date('M j, Y – H:i') }}
                  &mdash;
                  {{ conv.message_count }} {{ 'messages'|t }}
                </p>
                {% if conv.preview %}
                  <p class="forseti-conversations__preview text-secondary small mb-0">
                    {{ conv.preview|e }}&hellip;
                  </p>
                {% endif %}
              </div>
              <div class="forseti-conversations__actions ms-3 d-flex gap-2 flex-shrink-0">
                {# AC-4: Resume link #}
                <a href="{{ conv.chat_url }}" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-play-fill"></i> {{ 'Resume'|t }}
                </a>
                {# forseti-ai-conversation-export AC-4: Download link #}
                <a href="{{ conv.export_url }}" class="btn btn-sm btn-outline-secondary">
                  <i class="bi bi-download"></i> {{ 'Download'|t }}
                </a>
                {# AC-5: Delete button #}
                <form method="post" action="{{ delete_url }}" style="display:inline-block;">
                  <button type="submit" class="btn btn-sm btn-outline-danger"
                          onclick="return confirm('{{ 'Delete this conversation?'|t }}')">
                    <i class="bi bi-trash"></i> {{ 'Delete'|t }}
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {# AC-3: Pagination #}
    {% if has_prev or has_next %}
      <nav aria-label="{{ 'Conversation history pagination'|t }}" class="mt-4">
        <ul class="pagination justify-content-center">
          <li class="page-item {% if not has_prev %}disabled{% endif %}">
            <a class="page-link"
               href="?page={{ page - 1 }}"
               {% if not has_prev %}aria-disabled="true" tabindex="-1"{% endif %}>
              <i class="bi bi-chevron-left"></i> {{ 'Previous'|t }}
            </a>
          </li>
          <li class="page-item disabled" aria-current="page">
            <span class="page-link">{{ 'Page'|t }} {{ page }}</span>
          </li>
          <li class="page-item {% if not has_next %}disabled{% endif %}">
            <a class="page-link"
               href="?page={{ page + 1 }}"
               {% if not has_next %}aria-disabled="true" tabindex="-1"{% endif %}>
              {{ 'Next'|t }} <i class="bi bi-chevron-right"></i>
            </a>
          </li>
        </ul>
      </nav>
    {% endif %}

  {% endif %}

</div>
