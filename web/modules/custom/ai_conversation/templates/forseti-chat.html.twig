{#
  forseti-chat.html.twig
  User-facing AI chat page at /forseti/chat.
  Reuses the chat-interface JS behavior (attaches on .ai-conversation-chat container).
#}

<div class="ai-conversation-chat forseti-chat-page">
  <div class="chat-header">
    <h2>{{ 'AI Career Assistant'|t }}</h2>
  </div>

  <div class="chat-messages" id="chat-messages">
    {% if not messages or messages|length == 0 %}
      <div class="message message--assistant message--introduction">
        <div class="message-content">
          <p>{{ 'Welcome! I\'m your Forseti AI career assistant. I can help you with job searching, resume writing, interview preparation, and career development.'|t }}</p>
          <p>{{ 'What can I help you with today?'|t }}</p>
        </div>
      </div>
    {% endif %}

    {% for message in messages %}
      {% if message.role != 'system' %}
        <div class="message message--{{ message.role }}">
          <div class="message-content">
            {{ message.content|nl2br }}
          </div>
          {% if message.timestamp %}
            <div class="message-timestamp">
              {{ message.timestamp|date('M j, H:i') }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="chat-input-container">
    <div class="input-group">
      <textarea
        id="message-input"
        class="form-control"
        placeholder="{{ 'Type your message...'|t }}"
        rows="3"
        maxlength="4000"
      ></textarea>
      <button id="send-button" class="btn btn-primary" type="button">
        {{ 'Send'|t }}
      </button>
    </div>

    <div class="chat-controls">
      <button id="clear-input" class="btn btn-secondary btn-sm" type="button">
        {{ 'Clear'|t }}
      </button>
      {# AC-3: Export button — only when conversation has messages #}
      {% if export_url %}
        <a href="{{ export_url }}" class="btn btn-outline-secondary btn-sm ms-1"
           title="{{ 'Download this conversation as a text file'|t }}">
          <i class="bi bi-download"></i> {{ 'Download conversation'|t }}
        </a>
      {% endif %}
    </div>
  </div>

  <div id="loading-indicator" class="loading-indicator" style="display: none;">
    <div class="spinner"></div>
    <span>{{ 'AI is thinking...'|t }}</span>
  </div>
</div>
