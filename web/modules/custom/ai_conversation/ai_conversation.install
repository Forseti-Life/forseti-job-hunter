/**
 * Set default permissions for the conversation content type.
 */
function _ai_conversation_set_permissions() {
  $role_storage = \Drupal::entityTypeManager()->getStorage('user_role');
  
  // Give authenticated users permission to create conversations.
  $authenticated_role = $role_storage->load('authenticated');
  if ($authenticated_role) {
    $authenticated_role->grantPermission('create ai_conversation content');
    $authenticated_role->grantPermission('edit own ai_conversation content');
    $authenticated_role->grantPermission('delete own ai_conversation content');
    // Note: 'view own ai_conversation content' is not a valid core permission
    // Content access is handled by the node access system
    $authenticated_role->save();
  }
}

/**
 * Implements hook_uninstall().
 */
function ai_conversation_uninstall() {
  // WARNING: Do not remove fields or field storage during uninstall.
  // This would delete all conversation data permanently.
  
  // Only remove the content type configuration, not the fields or data.
  // This allows the module to be safely disabled/enabled without data loss.
  
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  
  // Count total conversations
  $conversation_query = $node_storage->getQuery()
    ->condition('type', 'ai_conversation')
    ->accessCheck(FALSE);
  $total_conversations = $conversation_query->count()->execute();

  // Count total suggestions
  $suggestion_query = $node_storage->getQuery()
    ->condition('type', 'community_suggestion')
    ->accessCheck(FALSE);
  $total_suggestions = $suggestion_query->count()->execute();

  $messages = [];
  
  // Handle ai_conversation content type
  if ($total_conversations == 0) {
    $conversation_type = NodeType::load('ai_conversation');
    if ($conversation_type) {
      $conversation_type->delete();
      \Drupal::logger('ai_conversation')->notice('Removed ai_conversation content type (no existing nodes found).');
      $messages[] = 'AI Conversation content type removed (no data found).';
    }
  } else {
    \Drupal::logger('ai_conversation')->warning('ai_conversation content type and @count conversations preserved during uninstall.', ['@count' => $total_conversations]);
    $messages[] = t('@count conversations preserved.', ['@count' => $total_conversations]);
  }
  
  // Handle community_suggestion content type
  if ($total_suggestions == 0) {
    $suggestion_type = NodeType::load('community_suggestion');
    if ($suggestion_type) {
      $suggestion_type->delete();
      \Drupal::logger('ai_conversation')->notice('Removed community_suggestion content type (no existing nodes found).');
      $messages[] = 'Community Suggestion content type removed (no data found).';
    }
  } else {
    \Drupal::logger('ai_conversation')->warning('community_suggestion content type and @count suggestions preserved during uninstall.', ['@count' => $total_suggestions]);
    $messages[] = t('@count suggestions preserved.', ['@count' => $total_suggestions]);
  }

  // Always remove module-specific configuration
  $config = \Drupal::configFactory()->getEditable('ai_conversation.settings');
  if (!$config->isNew()) {
    $config->delete();
    \Drupal::logger('ai_conversation')->notice('Removed ai_conversation module settings.');
  }
  
  // Display appropriate message
  if ($total_conversations > 0 || $total_suggestions > 0) {
    \Drupal::messenger()->addWarning(t('AI Conversation module uninstalled. @messages To completely remove all data, use: drush php-eval "_ai_conversation_complete_removal();"', ['@messages' => implode(' ', $messages)]));
  } else {
    \Drupal::messenger()->addStatus(t('AI Conversation module uninstalled successfully. @messages', ['@messages' => implode(' ', $messages)]));
  }
}

/**
 * Helper function to completely remove all AI conversation data and fields.
 * 
 * WARNING: This will permanently delete all conversation and suggestion data!
 * Only call this if you're absolutely sure you want to remove all data.
 * 
 * Usage: Run this via drush php-eval:
 * drush php-eval "_ai_conversation_complete_removal();"
 */
function _ai_conversation_complete_removal() {
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  
  // Delete all ai_conversation nodes
  $conversation_query = $node_storage->getQuery()
    ->condition('type', 'ai_conversation')
    ->accessCheck(FALSE);
  $conversation_nids = $conversation_query->execute();
  
  if (!empty($conversation_nids)) {
    $nodes = $node_storage->loadMultiple($conversation_nids);
    $node_storage->delete($nodes);
    \Drupal::logger('ai_conversation')->notice('Deleted @count AI conversation nodes.', ['@count' => count($conversation_nids)]);
  }
  
  // Delete all community_suggestion nodes
  $suggestion_query = $node_storage->getQuery()
    ->condition('type', 'community_suggestion')
    ->accessCheck(FALSE);
  $suggestion_nids = $suggestion_query->execute();
  
  if (!empty($suggestion_nids)) {
    $nodes = $node_storage->loadMultiple($suggestion_nids);
    $node_storage->delete($nodes);
    \Drupal::logger('ai_conversation')->notice('Deleted @count community suggestion nodes.', ['@count' => count($suggestion_nids)]);
  }
  
  // Remove the ai_conversation content type
  $conversation_type = NodeType::load('ai_conversation');
  if ($conversation_type) {
    $conversation_type->delete();
    \Drupal::logger('ai_conversation')->notice('Removed ai_conversation content type.');
  }
  
  // Remove the community_suggestion content type
  $suggestion_type = NodeType::load('community_suggestion');
  if ($suggestion_type) {
    $suggestion_type->delete();
    \Drupal::logger('ai_conversation')->notice('Removed community_suggestion content type.');
  }
  
  // Remove all ai_conversation field configurations and storage
  $conversation_fields = [
    'field_messages', 
    'field_ai_model', 
    'field_context',
    'field_conversation_summary',
    'field_message_count',
    'field_summary_updated',
    'field_summary_message_count',
    'field_total_tokens'
  ];
  
  foreach ($conversation_fields as $field_name) {
    // Remove field configuration
    $field_config = FieldConfig::loadByName('node', 'ai_conversation', $field_name);
    if ($field_config) {
      $field_config->delete();
    }
    
    // Remove field storage (this will delete all data in the field)
    $field_storage = FieldStorageConfig::loadByName('node', $field_name);
    if ($field_storage) {
      $field_storage->delete();
      \Drupal::logger('ai_conversation')->notice('Removed field storage for @field.', ['@field' => $field_name]);
    }
  }
  
  // Remove all community_suggestion field configurations and storage
  $suggestion_fields = [
    'field_suggestion_summary',
    'field_original_message',
    'field_conversation_reference',
    'field_suggestion_category',
    'field_suggestion_status'
  ];
  
  foreach ($suggestion_fields as $field_name) {
    // Remove field configuration
    $field_config = FieldConfig::loadByName('node', 'community_suggestion', $field_name);
    if ($field_config) {
      $field_config->delete();
    }
    
    // Remove field storage (this will delete all data in the field)
    $field_storage = FieldStorageConfig::loadByName('node', $field_name);
    if ($field_storage) {
      $field_storage->delete();
      \Drupal::logger('ai_conversation')->notice('Removed field storage for @field.', ['@field' => $field_name]);
    }
  }
  
  // Remove module configuration
  \Drupal::configFactory()->getEditable('ai_conversation.settings')->delete();
  
  \Drupal::messenger()->addStatus(t('Complete AI Conversation data removal finished. All conversation data has been permanently deleted.'));
}

/**
 * Initialize default system prompt configuration.
 */
function _ai_conversation_init_system_prompt() {
  // Use PromptManager to initialize the default system prompt.
  $prompt_manager = \Drupal::service('ai_conversation.prompt_manager');
  $prompt_manager->initializeDefaultPrompt();
}

/**
 * Update hook to add new summary fields to existing installations.
 */
function ai_conversation_update_8001() {
  // Add the new summary fields to existing installations.
  $fields_to_add = [
    'field_conversation_summary' => [
      'type' => 'text_long',
      'cardinality' => 1,
      'label' => 'Conversation Summary',
      'description' => 'Rolling summary of older conversation messages',
    ],
    'field_message_count' => [
      'type' => 'integer',
      'cardinality' => 1,
      'label' => 'Message Count',
      'description' => 'Total number of messages in this conversation',
      'default_value' => [['value' => 0]],
    ],
    'field_summary_updated' => [
      'type' => 'timestamp',
      'cardinality' => 1,
      'label' => 'Summary Updated',
      'description' => 'When the conversation summary was last updated',
    ],
  ];

  foreach ($fields_to_add as $field_name => $field_info) {
    // Create field storage if it doesn't exist.
    $field_storage = FieldStorageConfig::loadByName('node', $field_name);
    if (!$field_storage) {
      $field_storage = FieldStorageConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => $field_info['type'],
        'cardinality' => $field_info['cardinality'],
        'settings' => $field_info['settings'] ?? [],
      ]);
      $field_storage->save();
    }

    // Create field config if it doesn't exist.
    $field_config = FieldConfig::loadByName('node', 'ai_conversation', $field_name);
    if (!$field_config) {
      $field_config = FieldConfig::create([
        'field_storage' => $field_storage,
        'bundle' => 'ai_conversation',
        'label' => $field_info['label'],
        'description' => $field_info['description'],
        'required' => FALSE,
        'default_value' => $field_info['default_value'] ?? [],
        'settings' => [],
      ]);
      $field_config->save();
    }
  }

  // Update existing conversations to set initial message counts.
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $query = $node_storage->getQuery()
    ->condition('type', 'ai_conversation')
    ->accessCheck(FALSE);
  $nids = $query->execute();

  foreach ($nids as $nid) {
    $node = $node_storage->load($nid);
    if ($node) {
      // Count existing messages.
      $message_count = 0;
      if ($node->hasField('field_messages') && !$node->get('field_messages')->isEmpty()) {
        $message_count = count($node->get('field_messages')->getValue());
      }
      
      // Set the message count.
      $node->set('field_message_count', $message_count);
      $node->save();
    }
  }

  return t('Added conversation summary fields and updated existing conversations.');
}

