<?php

/**
 * @file
 * Install file for AI Conversation module.
 */

use Drupal\node\Entity\NodeType;
use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;

/**
 * Implements hook_schema().
 */
function ai_conversation_schema() {
  $schema['ai_conversation_api_usage'] = [
    'description' => 'Tracks all GenAI API calls across the system for cost monitoring and analysis',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
        'description' => 'Primary Key: Unique usage record ID',
      ],
      'timestamp' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when the API call was made',
      ],
      'uid' => [
        'type' => 'int',
        'not null' => FALSE,
        'default' => 0,
        'description' => 'User ID who triggered the API call',
      ],
      'module' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Module that made the API call (e.g., job_hunter, ai_conversation)',
      ],
      'operation' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Operation type (e.g., resume_parsing, chat_message, job_posting_parsing)',
      ],
      'model_id' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
        'description' => 'AWS Bedrock model identifier',
      ],
      'input_tokens' => [
        'type' => 'int',
        'not null' => FALSE,
        'default' => 0,
        'description' => 'Estimated input tokens sent to API',
      ],
      'output_tokens' => [
        'type' => 'int',
        'not null' => FALSE,
        'default' => 0,
        'description' => 'Estimated output tokens received from API',
      ],
      'stop_reason' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => FALSE,
        'default' => '',
        'description' => 'API stop reason (end_turn, max_tokens, etc.)',
      ],
      'duration_ms' => [
        'type' => 'int',
        'not null' => FALSE,
        'default' => 0,
        'description' => 'API call duration in milliseconds',
      ],
      'estimated_cost' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 6,
        'not null' => FALSE,
        'default' => 0,
        'description' => 'Estimated cost in USD based on token usage',
      ],
      'context_data' => [
        'type' => 'text',
        'size' => 'normal',
        'not null' => FALSE,
        'description' => 'JSON-encoded additional context (entity_id, queue_id, etc.)',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'timestamp' => ['timestamp'],
      'uid' => ['uid'],
      'module' => ['module'],
      'operation' => ['operation'],
      'module_operation' => ['module', 'operation'],
    ],
  ];

  return $schema;
}

/**
 * Implements hook_install().
 */
function ai_conversation_install() {
  // Create the conversation content type if it doesn't exist.
  $conversation_type = NodeType::load('ai_conversation');
  if (!$conversation_type) {
    $conversation_type = NodeType::create([
      'type' => 'ai_conversation',
      'name' => 'AI Conversation',
      'description' => 'A conversation with an AI model',
      'settings' => [
        'node' => [
          'options' => [
            'status' => TRUE,
            'promote' => FALSE,
            'sticky' => FALSE,
            'revision' => TRUE,
          ],
          'preview' => DRUPAL_DISABLED,
          'submitted' => TRUE,
        ],
      ],
    ]);
    $conversation_type->save();
    \Drupal::logger('ai_conversation')->notice('Created ai_conversation content type.');
  } else {
    \Drupal::logger('ai_conversation')->notice('ai_conversation content type already exists, skipping creation.');
  }

  // Create the community suggestion content type if it doesn't exist.
  $suggestion_type = NodeType::load('community_suggestion');
  if (!$suggestion_type) {
    $suggestion_type = NodeType::create([
      'type' => 'community_suggestion',
      'name' => 'Community Suggestion',
      'description' => 'A suggestion submitted by a community member through Forseti AI',
      'settings' => [
        'node' => [
          'options' => [
            'status' => TRUE,
            'promote' => FALSE,
            'sticky' => FALSE,
            'revision' => TRUE,
          ],
          'preview' => DRUPAL_DISABLED,
          'submitted' => TRUE,
        ],
      ],
    ]);
    $suggestion_type->save();
    \Drupal::logger('ai_conversation')->notice('Created community_suggestion content type.');
  } else {
    \Drupal::logger('ai_conversation')->notice('community_suggestion content type already exists, skipping creation.');
  }

  // Create fields for the conversation content type.
  _ai_conversation_create_fields();
  
  // Create fields for the suggestion content type.
  _ai_conversation_create_suggestion_fields();

  // Set default permissions.
  _ai_conversation_set_permissions();

  // Initialize default system prompt configuration.
  _ai_conversation_init_system_prompt();
}

/**
 * Create fields for the conversation content type.
 */
function _ai_conversation_create_fields() {
  $fields_to_create = [
    'field_messages' => [
      'type' => 'text_long',
      'cardinality' => -1, // Unlimited values
      'label' => 'Messages',
      'description' => 'Conversation messages',
      'settings' => [],
    ],
    'field_ai_model' => [
      'type' => 'string',
      'cardinality' => 1,
      'label' => 'AI Model',
      'description' => 'The AI model to use for this conversation',
      'required' => TRUE,
      'default_value' => [['value' => 'us.anthropic.claude-sonnet-4-5-20250929-v1:0']],
      'settings' => ['max_length' => 255],
    ],
    'field_context' => [
      'type' => 'text_long',
      'cardinality' => 1,
      'label' => 'Context',
      'description' => 'System prompt or conversation context',
      'settings' => [],
    ],
    'field_conversation_summary' => [
      'type' => 'text_long',
      'cardinality' => 1,
      'label' => 'Conversation Summary',
      'description' => 'Rolling summary of older conversation messages',
      'settings' => [],
    ],
    'field_message_count' => [
      'type' => 'integer',
      'cardinality' => 1,
      'label' => 'Message Count',
      'description' => 'Total number of messages in this conversation',
      'default_value' => [['value' => 0]],
      'settings' => [],
    ],
    'field_summary_updated' => [
      'type' => 'timestamp',
      'cardinality' => 1,
      'label' => 'Summary Updated',
      'description' => 'When the conversation summary was last updated',
      'settings' => [],
    ],
    'field_summary_message_count' => [
      'type' => 'integer',
      'cardinality' => 1,
      'label' => 'Summary Message Count',
      'description' => 'Counter for summary frequency logic',
      'default_value' => [['value' => 0]],
      'settings' => [],
    ],
    'field_total_tokens' => [
      'type' => 'integer',
      'cardinality' => 1,
      'label' => 'Total Tokens',
      'description' => 'Total tokens used in this conversation',
      'default_value' => [['value' => 0]],
      'settings' => [],
    ],
  ];

  foreach ($fields_to_create as $field_name => $field_info) {
    // Create field storage if it doesn't exist.
    $field_storage = FieldStorageConfig::loadByName('node', $field_name);
    if (!$field_storage) {
      $field_storage = FieldStorageConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => $field_info['type'],
        'cardinality' => $field_info['cardinality'],
        'settings' => $field_info['settings'],
      ]);
      $field_storage->save();
    }

    // Create field config if it doesn't exist.
    $field_config = FieldConfig::loadByName('node', 'ai_conversation', $field_name);
    if (!$field_config) {
      $field_config = FieldConfig::create([
        'field_storage' => $field_storage,
        'bundle' => 'ai_conversation',
        'label' => $field_info['label'],
        'description' => $field_info['description'],
        'required' => $field_info['required'] ?? FALSE,
        'default_value' => $field_info['default_value'] ?? [],
        'settings' => [],
      ]);
      $field_config->save();
    }
  }
}

