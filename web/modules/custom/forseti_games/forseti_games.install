<?php

/**
 * @file
 * Install, update and uninstall functions for the Forseti Games module.
 */

/**
 * Implements hook_schema().
 */
function forseti_games_schema() {
  $schema['forseti_games_high_scores'] = [
    'description' => 'Stores high scores for Forseti games.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
        'description' => 'Primary Key: Unique high score ID.',
      ],
      'game_id' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
        'description' => 'The game identifier (e.g., "block-matcher").',
      ],
      'score' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'The player score.',
      ],
      'level' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 1,
        'description' => 'The level reached.',
      ],
      'time' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Time in seconds.',
      ],
      'player_name' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => TRUE,
        'default' => 'Anonymous',
        'description' => 'Player name or message.',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Timestamp when the score was created.',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'game_score' => ['game_id', 'score'],
      'created' => ['created'],
    ],
  ];

  return $schema;
}

/**
 * Implements hook_install().
 */
function forseti_games_install() {
  // Populate initial high scores for Block Matcher
  $connection = \Drupal::database();
  
  for ($i = 0; $i < 10; $i++) {
    $connection->insert('forseti_games_high_scores')
      ->fields([
        'game_id' => 'block-matcher',
        'score' => 0,
        'level' => 1,
        'time' => 0,
        'player_name' => 'Empty Slot',
        'created' => time(),
      ])
      ->execute();
  }
}

/**
 * Create forseti_games_high_scores table if it was not created during install.
 */
function forseti_games_update_9001() {
  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('forseti_games_high_scores')) {
    $table_schema = forseti_games_schema();
    $schema->createTable('forseti_games_high_scores', $table_schema['forseti_games_high_scores']);
    // Seed empty slots.
    $connection = \Drupal::database();
    for ($i = 0; $i < 10; $i++) {
      $connection->insert('forseti_games_high_scores')
        ->fields([
          'game_id' => 'block-matcher',
          'score' => 0,
          'level' => 1,
          'time' => 0,
          'player_name' => 'Empty Slot',
          'created' => time(),
        ])
        ->execute();
    }
  }
}
