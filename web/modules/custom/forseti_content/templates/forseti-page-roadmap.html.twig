{#
/**
 * @file
 * Template for Forseti project roadmap page.
 *
 * Available variables:
 * - title: Page title.
 * - intro: Introductory copy.
 * - projects: Array of project roadmap cards.
 */
#}
<div class="container py-3">
  <div class="row">
    <div class="col-lg-10 mx-auto">
      <h1 class="text-center mb-3 text-cyan">{{ title }}</h1>

      <div class="lead mb-4 text-muted-light">
        {{ intro }}
      </div>

      <div class="row">
        {% for project in projects %}
          <div class="col-12 mb-4">
            <div class="card card-forseti p-4 h-100">
              <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start mb-3">
                <div>
                  <h2 class="h3 text-cyan mb-2">{{ project.title }}</h2>
                  <p class="mb-2">{{ project.summary }}</p>
                  {% if project.meta %}
                    <p class="small text-muted mb-2">{{ project.meta }}</p>
                  {% endif %}
                </div>
                <span class="badge bg-info text-dark mt-2 mt-md-0">{{ project.status }}</span>
              </div>

              <h3 class="h5 text-cyan">{{ 'Roadmap'|t }}</h3>
              <ul class="mb-0">
                {% for item in project.roadmap %}
                  <li class="mb-2">{{ item }}</li>
                {% endfor %}
              </ul>

              {% if project.pipeline_counts and project.pipeline_counts.total > 0 %}
                <div class="mt-3">
                  <div class="progress mb-1" style="height: 8px;" title="{{ project.pipeline_counts.impl_pct }}% shipped">
                    <div class="progress-bar bg-success" role="progressbar"
                      style="width: {{ project.pipeline_counts.impl_pct }}%"></div>
                    {% set prog_width = project.pipeline_counts.progress_pct - project.pipeline_counts.impl_pct %}
                    {% if prog_width > 0 %}
                      <div class="progress-bar bg-warning" role="progressbar"
                        style="width: {{ prog_width }}%"></div>
                    {% endif %}
                  </div>
                  <div class="small text-muted">
                    ✅ {{ project.pipeline_counts.implemented }} shipped
                    {% if project.pipeline_counts.in_progress + project.pipeline_counts.queued > 0 %}
                      · 🔄 {{ project.pipeline_counts.in_progress + project.pipeline_counts.queued }} in&nbsp;progress
                    {% endif %}
                    {% if project.pipeline_counts.pending > 0 %}
                      · ⏳ {{ project.pipeline_counts.pending }} backlog
                    {% endif %}
                    &nbsp;({{ project.pipeline_counts.total }} features)
                  </div>
                </div>
              {% endif %}

              {% if project.actions %}
                <div class="mt-3">
                  {% for action in project.actions %}
                    <a href="{{ action.url }}" class="btn {% if action.style == 'primary' %}btn-outline-primary{% else %}btn-outline-secondary{% endif %} me-2 mb-2">{{ action.text }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
