<?php

/**
 * @file
 * Contains institutional_management.module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function institutional_management_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.institutional_management':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('The Institutional Management module provides enterprise-level features for managing organizational accounts, group structures, and institutional safety assessments.') . '</p>';
      $output .= '<h3>' . t('Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Create and manage institutional groups') . '</li>';
      $output .= '<li>' . t('Define organizational hierarchies and departments') . '</li>';
      $output .= '<li>' . t('Manage employee accounts and access levels') . '</li>';
      $output .= '<li>' . t('Bulk location analysis and safety assessments') . '</li>';
      $output .= '<li>' . t('Compliance reports and institutional analytics') . '</li>';
      $output .= '<li>' . t('API access for enterprise integrations') . '</li>';
      $output .= '</ul>';
      return $output;
  }
}

/**
 * Implements hook_theme().
 */
function institutional_management_theme($existing, $type, $theme, $path) {
  return [
    'institutional_dashboard' => [
      'variables' => [
        'institution' => NULL,
        'members' => [],
        'statistics' => [],
      ],
      'template' => 'institutional-dashboard',
    ],
    'group_location_map' => [
      'variables' => [
        'group' => NULL,
        'members' => [],
        'map_config' => [],
      ],
      'template' => 'group-location-map',
    ],
  ];
}

/**
 * Implements hook_form_alter().
 */
function institutional_management_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  // Apply Bootstrap styling to family and institution group forms.
  if (in_array($form_id, ['group_family_add_form', 'group_family_edit_form', 'group_institution_add_form', 'group_institution_edit_form'])) {
    // Add container wrapper classes.
    $form['#attributes']['class'][] = 'container';
    $form['#attributes']['class'][] = 'my-5';
    
    // Wrap the form in a centered card.
    $form['#prefix'] = '<div class="row justify-content-center"><div class="col-lg-8"><div class="card shadow-sm"><div class="card-body p-4">';
    $form['#suffix'] = '</div></div></div></div>';
  }
}
